@page
@model acc_finance.Pages.DebtTracker.IndexModel
@{
    ViewData["Title"] = "Inter-Fund Loans";
}

<div class="container-fluid py-4" style="max-width: 1200px;">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0 text-dark"><i class="bi bi-bank text-warning me-2"></i> Debt Tracker</h2>
            <p class="text-muted mb-0 fs-6">Master list of all inter-fund loans and repayments.</p>
        </div>
    </div>

    <!-- Summary Cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-4 h-100 bg-danger bg-opacity-10 text-danger p-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-uppercase fw-bold small" style="letter-spacing: 0.05em;">Total Active Debt</div>
                        <h2 class="fw-bold mb-0 mt-1">₱ @Model.TotalActiveDebt.ToString("N2")</h2>
                    </div>
                    <i class="bi bi-exclamation-circle opacity-50 display-6"></i>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-4 h-100 bg-success bg-opacity-10 text-success p-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-uppercase fw-bold small" style="letter-spacing: 0.05em;">Total Successfully Repaid</div>
                        <h2 class="fw-bold mb-0 mt-1">₱ @Model.TotalRepaid.ToString("N2")</h2>
                    </div>
                    <i class="bi bi-check2-circle opacity-50 display-6"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Master Ledger Table -->
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-muted small text-uppercase">
                        <tr>
                            <th class="px-4 py-3">Date</th>
                            <th class="py-3">Borrower Fund</th>
                            <th class="py-3">Lender Fund</th>
                            <th class="py-3 text-end">Original Loan</th>
                            <th class="py-3 text-end">Paid Amount</th>
                            <th class="py-3 text-end">Remaining Debt</th>
                            <th class="py-3 text-center">Status</th>
                            <th class="px-4 py-3 text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.AllLoans.Any())
                        {
                            <tr><td colspan="7" class="text-center py-5 text-muted">No loans have been recorded yet.</td></tr>
                        }

                        @foreach (var loan in Model.AllLoans)
                        {
                            <tr>
                                <td class="px-4 fw-medium text-secondary">@loan.RecordDate.ToString("MMM dd, yyyy")</td>
                                <td class="fw-bold text-danger"><i class="bi bi-arrow-down-left me-1"></i> @loan.BorrowerFund</td>
                                <td class="fw-bold text-success"><i class="bi bi-arrow-up-right me-1"></i> @loan.LenderFund</td>
                                <td class="text-end text-muted">₱ @loan.OriginalAmount.ToString("N2")</td>
                                <td class="text-end fw-bold text-success">
                                    ₱ @((loan.OriginalAmount - loan.RemainingBalance).ToString("N2"))
                                </td>
                                <td class="text-end fw-bold text-dark">₱ @loan.RemainingBalance.ToString("N2")</td>
                                <td class="text-center">
                                    @if (loan.Status == "Active")
                                    {
                                        <span class="badge bg-warning text-dark border border-warning px-2 py-1">ACTIVE</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-success border border-success border-opacity-25 px-2 py-1">PAID</span>
                                    }
                                </td>
                                <td class="px-4 text-center">
                                    @if (loan.Status == "Active")
                                    {
                                        <a href="/DebtTracker/Pay?LoanId=@loan.Id" class="btn btn-sm btn-success shadow-sm rounded-pill fw-bold px-3 py-1" style="font-size: 0.75rem; letter-spacing: 0.05em;">
                                            PAY NOW
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted small"><i class="bi bi-check-lg"></i> Cleared</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>