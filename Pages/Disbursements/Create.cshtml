@page
@model acc_finance.Pages.Disbursements.CreateModel
@using System.Text.Json
@{
    ViewData["Title"] = "Cash Disbursement";
    var initialTemplatesJson = JsonSerializer.Serialize(
    (Model.FixedTemplates ?? new List<acc_finance.Pages.Disbursements.TemplatePayloadVm>())
        .Select(t => new
        {
            id = t.Id,
            templateName = t.TemplateName,
            ministry = t.Ministry,
            payee = t.Payee,
            totalInput = t.TotalInput,
            autoApply = t.AutoApply,
            recurrenceType = t.RecurrenceType,
            weekOfMonth = t.WeekOfMonth,
            items = (t.Items ?? new List<acc_finance.Pages.Disbursements.TemplateItemPayloadVm>())
                .Select(i => new
                {
                    lineNo = i.LineNo,
                    particular = i.Particular,
                    fundSource = i.FundSource,
                    amount = i.Amount
                }).ToList()
        }).ToList()
        );
    var initialSheetJson = JsonSerializer.Serialize(new
    {
        vouchers = (Model.Sheet?.Vouchers ?? new List<acc_finance.Pages.Disbursements.VoucherVm>())
            .Select(v => new
            {
                voucherNumber = v.VoucherNumber,
                ministry = v.Ministry,
                payee = v.Payee,
                totalInput = v.TotalInput,
                items = (v.Items ?? new List<acc_finance.Pages.Disbursements.VoucherItemVm>())
                    .Select(i => new
                    {
                        particular = i.Particular,
                        fundSource = i.FundSource,
                        amount = i.Amount,
                        amountReturned = i.AmountReturned
                    }).ToList()
            }).ToList()
    });

    var activeMinistriesJson = JsonSerializer.Serialize(Model.ActiveMinistries);
    var activeWalletsJson = JsonSerializer.Serialize(Model.ActiveWallets);
}

<style>
    /* --- MODERN STYLING --- */
    .disb-page {
        font-size: 0.9rem;
    }

    .card-modern {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
    }

    .sheet-head {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        gap: 1rem;
        flex-wrap: wrap;
        border-bottom: 2px solid #e2e8f0;
        padding-bottom: 1rem;
        margin-bottom: 1.5rem;
    }

    .sheet-title {
        font-size: 1.2rem;
        font-weight: 700;
        color: #0f172a;
        margin: 0;
        text-transform: uppercase;
        letter-spacing: -0.01em;
    }

    .sheet-sub {
        color: #64748b;
        font-size: 0.85rem;
        margin-top: 0.2rem;
    }

    .form-label {
        font-size: 0.8rem;
        font-weight: 600;
        color: #475569;
        margin-bottom: 4px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .inline-input, .inline-select {
        font-size: 0.9rem;
        border-radius: 8px;
        border: 1px solid #cbd5e1;
        padding: 0.45rem 0.75rem;
        background: #fff;
    }

        .inline-input:focus, .inline-select:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.15);
            outline: none;
        }

    .field-readonly {
        background: #f8fafc;
        font-weight: 700;
        color: #0f172a;
        border-color: #e2e8f0;
    }

    .field-blank {
        visibility: hidden;
        pointer-events: none;
    }

    .money-return {
        color: #dc2626 !important;
        font-weight: 600;
    }
    /* Grid Layouts */
    .sheet-grid, .voucher-line, .sheet-total-row, .summary-row {
        display: grid;
        grid-template-columns: minmax(0, 1.8fr) 140px 110px 110px 100px 100px;
        gap: 12px;
        align-items: center;
    }

    .sheet-grid {
        background: #f8fafc;
        padding: 12px 16px;
        border: 1px solid #e2e8f0;
        border-radius: 8px 8px 0 0;
        font-weight: 600;
        color: #475569;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .cash-return-head {
        color: #dc2626;
        text-align: right;
    }

    .head-right, .voucher-line .text-end, .sheet-total-row .text-end, .summary-row .text-end {
        text-align: right;
    }
    /* Voucher Cards */
    .voucher-card {
        border: 1px solid #e2e8f0;
        border-top: none;
        padding: 16px;
        background: #ffffff;
        transition: background 0.15s ease;
    }

        .voucher-card:hover {
            background: #f8fafc;
        }

        .voucher-card:last-of-type {
            border-radius: 0 0 8px 8px;
        }

    .voucher-headline {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 0.75rem;
        padding-bottom: 0.75rem;
        border-bottom: 1px dashed #e2e8f0;
    }

    .voucher-ministry {
        width: 140px;
        flex: 0 0 140px;
        font-weight: 600;
    }

    .voucher-payee {
        width: 220px;
        flex: 0 0 220px;
        font-weight: 600;
        color: #0f172a;
    }

    .voucher-dash {
        font-weight: 700;
        color: #94a3b8;
    }

    .voucher-line {
        margin-bottom: 0.5rem;
    }

    .voucher-actions {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
        margin-top: 0.75rem;
    }

    .add-voucher-wrap {
        display: flex;
        justify-content: center;
        margin-top: 1.5rem;
    }
    /* Totals & Summary */
    .sheet-total-row {
        margin-top: 1.5rem;
        background: #f8fafc;
        border: 2px solid #cbd5e1;
        border-radius: 8px;
        padding: 16px;
        font-size: 1rem;
        font-weight: 700;
        color: #0f172a;
    }

    .summary-wrap {
        margin-top: 1.5rem;
        width: 100%;
        max-width: 600px;
        background: #f8fafc;
        border: 1px solid #cbd5e1;
        border-radius: 8px;
        padding: 20px;
    }

    .summary-row {
        display: flex;
        justify-content: space-between;
        padding: 8px 0;
        font-size: 0.95rem;
        color: #334155;
    }

    .summary-label {
        font-weight: 600;
        color: #475569;
    }

    .summary-value-strong {
        font-weight: 700;
        color: #0f172a;
    }

    .summary-net-row {
        display: flex;
        justify-content: space-between;
        padding-top: 16px;
        margin-top: 8px;
        border-top: 2px solid #94a3b8;
        font-size: 1.1rem;
        font-weight: 800;
        color: #0f172a;
    }

    .net-box {
        color: #15803d;
    }

    .bottom-actions {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: 1rem;
        margin-top: 2rem;
        padding-top: 1.5rem;
        border-top: 1px solid #e2e8f0;
    }
    /* --- NEW TEMPLATE DASHBOARD UI --- */
    .template-dash-container {
        background: #f8fafc;
        border-radius: 12px;
        padding: 20px;
        border: 1px solid #e2e8f0;
    }

    .nav-pills-custom .nav-link {
        font-weight: 600;
        color: #64748b;
        border-radius: 8px;
        padding: 10px 20px;
        margin-right: 10px;
        border: 1px solid transparent;
        transition: all 0.2s;
    }

        .nav-pills-custom .nav-link.active {
            background: #3b82f6;
            color: #fff;
            box-shadow: 0 4px 6px -1px rgba(59, 130, 246, 0.4);
        }

    .sunday-block {
        background: #fff;
        border: 1px solid #cbd5e1;
        border-radius: 12px;
        padding: 16px;
        margin-bottom: 16px;
    }

    .sunday-header {
        font-size: 1.05rem;
        font-weight: 700;
        color: #0f172a;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 2px solid #f1f5f9;
        padding-bottom: 10px;
        margin-bottom: 12px;
    }

    .sched-item {
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        padding: 12px 16px;
        background: #f8fafc;
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 8px;
    }

    .sched-item-info {
        font-weight: 600;
        color: #1e293b;
        font-size: 0.95rem;
    }

    .sched-item-meta {
        font-size: 0.85rem;
        color: #64748b;
    }

    .sched-item-amount {
        font-weight: 700;
        color: #0f172a;
        font-size: 1rem;
    }

    .inline-editor-box {
        background: #f1f5f9;
        border: 1px solid #cbd5e1;
        border-radius: 8px;
        padding: 16px;
        margin-top: 12px;
    }

    .toast-wrap-fixed {
        position: fixed;
        right: 20px;
        bottom: 20px;
        z-index: 1095;
    }

    @@media (max-width: 992px) {
        .sheet-grid, .voucher-line, .sheet-total-row {
            grid-template-columns: 1fr;
            gap: .5rem;
        }

        .voucher-headline {
            flex-wrap: wrap;
        }

        .voucher-ministry, .voucher-payee {
            width: 100%;
            flex: 1 1 100%;
        }

        .field-blank {
            display: none;
        }

        .sheet-total-row {
            grid-template-columns: 1fr 100px;
            justify-content: space-between;
        }
    }
</style>

<div class="container-fluid disb-page py-4">
    <div class="card-modern p-4 p-md-5">
        @if (!ModelState.IsValid)
        {
            <div class="alert alert-danger" style="border-radius: 8px;">
                <div asp-validation-summary="All"></div>
            </div>
        }

        <form method="post" id="sheetForm">
            @Html.AntiForgeryToken()
            <input asp-for="SheetJson" type="hidden" id="SheetJson" />

            <div class="sheet-head">
                <div>
                    <h1 class="sheet-title">Cash Disbursement</h1>
                    
                </div>

                <div class="d-flex align-items-end gap-3 flex-wrap">
                    <div>
                        <label class="form-label">Record Date</label>
                        <input asp-for="RecordDate" type="date" class="form-control inline-input fw-bold text-primary" id="recordDateInput" style="height: 40px;" />
                    </div>

                    <button type="button" class="btn btn-dark fw-semibold shadow-sm" id="openTemplateSettingsBtn" style="border-radius: 8px; height: 40px;">
                        <i class="bi bi-calendar-week me-1"></i> Master Schedules
                    </button>

                    <button type="button" class="btn btn-outline-primary fw-semibold shadow-sm" id="useTemplateBtn" style="border-radius: 8px; height: 40px;">
                        <i class="bi bi-download me-1"></i> Force Load Template
                    </button>
                </div>
            </div>

            @if (Model.Sheet.HasAutoLoadedTemplates)
            {
                <div class="alert alert-primary shadow-sm" style="border-radius: 8px; border-left: 5px solid #0d6efd;">
                    <i class="bi bi-check-circle-fill me-2"></i> <strong>@Model.Sheet.AutoLoadedTemplateCount</strong> scheduled vouchers were automatically loaded based on the date.
                </div>
            }

            <div class="sheet-grid">
                <div>PARTICULARS</div>
                <div>FUND SOURCE</div>
                <div class="head-right">AMOUNT</div>
                <div class="head-right">TOTAL</div>
                <div class="head-right">VOUCHER #</div>
                <div class="cash-return-head">CASH RETURN</div>
            </div>

            <div id="voucherList"></div>

            <div class="add-voucher-wrap">
                <button type="button" class="btn btn-light border fw-bold text-primary shadow-sm px-4 py-2" id="addVoucherBtn" style="border-radius: 8px;">
                    <i class="bi bi-plus-circle me-1"></i> Add Blank Voucher
                </button>
            </div>

            <div class="sheet-total-row">
                <div class="d-none d-lg-block">GRAND TOTAL</div>
                <div class="d-none d-lg-block"></div>
                <div class="d-none d-lg-block"></div>
                <div class="text-end" id="grandTotalText">0.00</div>
                <div class="d-none d-lg-block"></div>
                <div class="text-end money-return" id="grandReturnText">0.00</div>
            </div>

            <div class="summary-wrap">
                <div class="summary-row">
                    <span class="summary-label">Adjusted Disbursement</span>
                    <span class="text-end summary-value-strong" id="adjustedDisbursementText">0.00</span>
                </div>

                <div class="summary-row">
                    <span class="summary-label">Cash Receipts / Blessings</span>
                    <span class="text-end" id="blessingText">@Model.Sheet.Blessing.ToString("N2")</span>
                </div>

                <div class="summary-row">
                    <span class="summary-label">Less: Cash Disbursements</span>
                    <span class="text-end" id="lessDisbursementText">0.00</span>
                </div>

                <div class="summary-net-row">
                    <span>NET CASH BALANCE</span>
                    <span class="net-box" id="netCashBalanceText">0.00</span>
                </div>
            </div>

            <div class="bottom-actions d-flex align-items-center justify-content-end gap-3 mt-4 pt-3 border-top">
                <button type="button" id="preSaveBtn" class="btn btn-success fw-bold px-5 py-2 shadow-sm" style="border-radius: 8px;">
                    <i class="bi bi-check2-circle me-1"></i> Save Sheet
                </button>
            </div>
        </form>
    </div>
</div>

<div class="modal fade" id="templateModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-white border-bottom pb-3">
                <h4 class="modal-title fw-bold text-dark"><i class="bi bi-calendar-week text-primary me-2"></i>Master Schedules</h4>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body bg-light pt-4">
                <div class="template-dash-container">
                    <ul class="nav nav-pills nav-pills-custom mb-4" id="scheduleTabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active" id="tab-4week-btn" data-bs-toggle="pill" data-bs-target="#tab-4week" type="button" role="tab">4-Week Month Schedule</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="tab-5week-btn" data-bs-toggle="pill" data-bs-target="#tab-5week" type="button" role="tab">5-Week Month Schedule</button>
                        </li>
                    </ul>

                    <div class="tab-content" id="scheduleTabsContent">
                        <div class="tab-pane fade show active" id="tab-4week" role="tabpanel">
                            <div class="row g-4" id="render-4week"></div>
                        </div>

                        <div class="tab-pane fade" id="tab-5week" role="tabpanel">
                            <div class="row g-4" id="render-5week"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="useTemplateModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-light border-bottom-0 pb-3">
                <h5 class="modal-title fw-bold text-dark">Force Load Master Schedule</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body bg-light pt-2 pb-4">
                <label class="form-label">Select Schedule Configuration to Load</label>
                <select id="manualLoadSelect" class="form-select border-primary shadow-sm" style="height: 45px; border-radius: 8px;">
                    <optgroup label="4-Week Month">
                        <option value="4_week|1">1st Sunday</option>
                        <option value="4_week|2">2nd Sunday</option>
                        <option value="4_week|3">3rd Sunday</option>
                        <option value="4_week|4">4th Sunday</option>
                    </optgroup>
                    <optgroup label="5-Week Month">
                        <option value="5_week|1">1st Sunday</option>
                        <option value="5_week|2">2nd Sunday</option>
                        <option value="5_week|3">3rd Sunday</option>
                        <option value="5_week|4">4th Sunday</option>
                        <option value="5_week|5">5th Sunday</option>
                    </optgroup>
                </select>
                <div class="text-muted mt-3" style="font-size:0.85rem;">
                    <i class="bi bi-info-circle me-1"></i> The system automatically loads the correct schedule based on the Record Date. Use this only if you need to manually override or add a different week's vouchers.
                </div>
            </div>

            <div class="modal-footer border-top-0 bg-light pt-0">
                <button type="button" class="btn btn-primary fw-bold px-4" id="applyManualScheduleBtn" style="border-radius: 8px;">Load Vouchers</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteTemplateModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-bottom-0 pb-0">
                <h5 class="modal-title fw-bold text-dark">Remove Scheduled Voucher</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body pt-2 text-muted">
                Are you sure you want to remove this voucher from the master schedule?
                <br><br>
                <div class="p-3 bg-light rounded border border-danger">
                    <i class="bi bi-exclamation-triangle-fill text-danger me-2"></i> This action cannot be undone.
                </div>
            </div>
            <div class="modal-footer border-top-0 pt-0">
                <input type="hidden" id="deleteTemplateId" value="" />
                <button class="btn btn-light border fw-semibold text-muted" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-danger fw-bold" id="confirmDeleteTemplateBtn">Yes, Remove</button>
            </div>
        </div>
    </div>
</div>

<div class="toast-wrap-fixed">
    <div id="uiToast" class="toast align-items-center border-0 shadow" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div id="uiToastBody" class="toast-body fw-semibold text-white"></div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>


<partial name="_ValidationScriptsPartial" />

<script>
    (() => {
        let fixedTemplates = @Html.Raw(initialTemplatesJson);
        if (!Array.isArray(fixedTemplates)) fixedTemplates = [];

        const ministryOptions = @Html.Raw(activeMinistriesJson);
        const fundOptions = @Html.Raw(activeWalletsJson);

        let sheet = @Html.Raw(initialSheetJson);

        const currentRecordDate = document.getElementById("recordDateInput")?.value || "";
        const draftKey = "DisbDraft_" + currentRecordDate;

        const savedDraft = sessionStorage.getItem(draftKey);
        if (savedDraft) {
            try {
                const parsedDraft = JSON.parse(savedDraft);
                if (parsedDraft && Array.isArray(parsedDraft.vouchers) && parsedDraft.vouchers.length > 0) {
                    sheet = parsedDraft;
                }
            } catch(e) { }
        }

        if (!sheet || !Array.isArray(sheet.vouchers)) sheet = { vouchers: [] };
        if (sheet.vouchers.length === 0) sheet.vouchers.push(createEmptyVoucher());

        function showToast(message, type = "success") {
            const toastEl = document.getElementById("uiToast");
            const bodyEl = document.getElementById("uiToastBody");
            if (!toastEl || !bodyEl) return;

            toastEl.className = "toast align-items-center border-0 shadow";
            if (type === "success") toastEl.classList.add("bg-success");
            else if (type === "error") toastEl.classList.add("bg-danger");
            else if (type === "warning") toastEl.classList.add("bg-warning");
            else toastEl.classList.add("bg-primary");

            bodyEl.textContent = message;
            const toast = bootstrap.Toast.getOrCreateInstance(toastEl, { delay: 2500 });
            toast.show();
        }

        function createEmptyVoucher() {
            return {
                voucherNumber: "", ministry: "", payee: "", totalInput: 0,
                items: [{ particular: "", fundSource: "General", amount: 0, amountReturned: 0 }]
            };
        }

        function createEmptyItem() {
            return { particular: "", fundSource: "General", amount: 0, amountReturned: 0 };
        }

        function escapeHtml(value) {
            return (value ?? "").toString().replaceAll("&", "&amp;").replaceAll("<", "&lt;").replaceAll(">", "&gt;").replaceAll('"', "&quot;");
        }

        function parseMoney(value) {
            if (value === null || value === undefined || value === "") return 0;
            const n = parseFloat(value);
            return isNaN(n) ? 0 : n;
        }

        function formatMoney(value) {
            return parseMoney(value).toLocaleString("en-US", { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        }

        function isSingleItemVoucher(voucher) { return (voucher.items || []).length === 1; }
        function voucherReleasedTotal(voucher) {
            if (isSingleItemVoucher(voucher)) return parseMoney(voucher.totalInput);
            return (voucher.items || []).reduce((sum, item) => sum + parseMoney(item.amount), 0);
        }
        function voucherReturnedTotal(voucher) {
            return (voucher.items || []).reduce((sum, item) => sum + parseMoney(item.amountReturned), 0);
        }

        function clampItemReturn(item, voucher) {
            const maxBase = isSingleItemVoucher(voucher) ? parseMoney(voucher.totalInput) : parseMoney(item.amount);
            let returned = parseMoney(item.amountReturned);
            if (returned < 0) returned = 0;
            if (returned > maxBase) returned = maxBase;
            item.amountReturned = returned;
        }

        function normalizeVoucher(voucher) {
            voucher.items = voucher.items || [];
            if (voucher.items.length === 0) voucher.items.push(createEmptyItem());

            if (isSingleItemVoucher(voucher)) {
                voucher.totalInput = parseMoney(voucher.totalInput);
                voucher.items[0].amount = 0;
                voucher.items[0].fundSource = voucher.items[0].fundSource || "General";
                clampItemReturn(voucher.items[0], voucher);
            } else {
                voucher.items.forEach(item => {
                    item.amount = parseMoney(item.amount);
                    item.fundSource = item.fundSource || "General";
                    clampItemReturn(item, voucher);
                });
                voucher.totalInput = voucher.items.reduce((sum, item) => sum + parseMoney(item.amount), 0);
            }
        }

        function buildMinistryOptions(selectedValue) {
            let html = `<option value="">-- Select --</option>`;
            let found = false;
            for (const option of ministryOptions) {
                const isSelected = option === selectedValue;
                if (isSelected) found = true;
                html += `<option value="${escapeHtml(option)}" ${isSelected ? "selected" : ""}>${escapeHtml(option)}</option>`;
            }
            // Fallback: If a voucher contains a ministry that was later deleted, still show it to prevent data loss.
            if (selectedValue && !found) {
                html += `<option value="${escapeHtml(selectedValue)}" selected>${escapeHtml(selectedValue)} (Inactive)</option>`;
            }
            return html;
        }

        function buildFundOptions(selectedValue) {
            let html = ``;
            let found = false;
            for (const f of fundOptions) {
                const isSelected = f === selectedValue;
                if (isSelected) found = true;
                html += `<option value="${escapeHtml(f)}" ${isSelected ? "selected" : ""}>${escapeHtml(f)}</option>`;
            }
            
            if (selectedValue && !found) {
                html += `<option value="${escapeHtml(selectedValue)}" selected>${escapeHtml(selectedValue)} (Inactive)</option>`;
            }
            return html;
        }

        function buildVoucherFromTemplate(template) {
            const items = (template.items || []).map(x => ({
                particular: x.particular, fundSource: x.fundSource || "General",
                amount: (template.items || []).length === 1 ? 0 : parseMoney(x.amount),
                amountReturned: 0
            }));
            return {
                voucherNumber: "", ministry: template.ministry || "", payee: template.payee || "",
                totalInput: (template.items || []).length === 1 ? parseMoney(template.items[0]?.amount || 0) : parseMoney(template.totalInput || 0),
                items: items.length ? items : [{ particular: "", fundSource: "General", amount: 0, amountReturned: 0 }]
            };
        }

        // ====================================================
        // NEW SCHEDULE UI RENDERER
        // ====================================================

        function renderScheduleUI() {
            const week4Container = document.getElementById("render-4week");
            const week5Container = document.getElementById("render-5week");
            if(!week4Container || !week5Container) return;

            week4Container.innerHTML = buildSundayBlocks("4_week", 4);
            week5Container.innerHTML = buildSundayBlocks("5_week", 5);
        }

        function buildSundayBlocks(type, maxWeeks) {
            let html = "";
            for(let w = 1; w <= maxWeeks; w++) {
                const vouchers = fixedTemplates.filter(t => t.recurrenceType === type && t.weekOfMonth === w);
                html += `
                    <div class="col-md-6">
                        <div class="sunday-block">
                            <div class="sunday-header">
                                <span>${w}${getOrdinal(w)} Sunday</span>
                                <button type="button" class="btn btn-sm btn-primary fw-semibold add-schedule-voucher-btn" data-type="${type}" data-week="${w}">+ Add Voucher</button>
                            </div>
                            <div class="sched-list-wrapper" id="sched-list-${type}-${w}">
                                ${vouchers.length === 0 ? `<div class="text-muted text-center py-3" style="font-size:0.85rem;">No vouchers scheduled.</div>` :
                                    vouchers.map(v => `
                                    <div class="sched-item">
                                        <div>
                                            <div class="sched-item-info">${escapeHtml(v.ministry)} - ${escapeHtml(v.payee)}</div>
                                            <div class="sched-item-meta">${v.items.length} particular(s)</div>
                                        </div>
                                        <div class="text-end">
                                            <div class="sched-item-amount">${formatMoney(v.totalInput)}</div>
                                            <div class="mt-1">
                                                <a href="#" class="text-decoration-none text-primary me-2 edit-sched-btn" data-id="${v.id}" style="font-size:0.8rem;">Edit</a>
                                                <a href="#" class="text-decoration-none text-danger delete-sched-btn" data-id="${v.id}" style="font-size:0.8rem;">Remove</a>
                                            </div>
                                        </div>
                                    </div>
                                `).join('')}
                            </div>
                            <div class="inline-editor-box d-none" id="editor-${type}-${w}"></div>
                        </div>
                    </div>
                `;
            }
            return html;
        }

        function getOrdinal(n) {
            const s = ["th", "st", "nd", "rd"];
            const v = n % 100;
            return s[(v - 20) % 10] || s[v] || s[0];
        }

        function closeAllEditors() {
            document.querySelectorAll(".inline-editor-box").forEach(el => {
                el.innerHTML = "";
                el.classList.add("d-none");
            });
            document.querySelectorAll(".sched-list-wrapper").forEach(el => {
                el.classList.remove("d-none");
            });
        }

        function openEditor(type, week, templateId = 0) {
            closeAllEditors();
            const editorBox = document.getElementById(`editor-${type}-${week}`);
            const listWrap = document.getElementById(`sched-list-${type}-${week}`);
            if(!editorBox) return;

            if(listWrap) listWrap.classList.add("d-none");
            editorBox.classList.remove("d-none");
            let tData = { id: 0, ministry: "", payee: "", items: [{particular: "", fundSource: "General", amount: 0}] };
            if (templateId > 0) {
                const found = fixedTemplates.find(x => x.id === templateId);
                if (found) tData = JSON.parse(JSON.stringify(found));
            }

            editorBox.innerHTML = `
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="fw-bold text-dark">${templateId === 0 ? "New Voucher" : "Edit Voucher"}</span>
                </div>
                <div class="row g-2 mb-2">
                    <div class="col-12">
                        <label class="form-label" style="font-size:0.7rem;">Ministry</label>
                        <select class="form-select inline-select" id="ed-min-${type}-${week}">
                            ${buildMinistryOptions(tData.ministry)}
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label" style="font-size:0.7rem;">Payee</label>
                        <input type="text" class="form-control inline-input" id="ed-pay-${type}-${week}" value="${escapeHtml(tData.payee)}">
                    </div>
                </div>
                <label class="form-label mt-2" style="font-size:0.7rem;">Particulars</label>
                <div id="ed-items-${type}-${week}"></div>

                <button type="button" class="btn btn-sm btn-light border text-primary w-100 fw-bold mt-2" id="ed-add-item-${type}-${week}">+ Add Sub-Item</button>

                <div class="d-flex justify-content-end gap-2 mt-3 pt-3 border-top">
                    <button type="button" class="btn btn-sm btn-outline-secondary px-3 ed-cancel-btn">Cancel</button>
                    <button type="button" class="btn btn-sm btn-success fw-bold px-3 ed-save-btn" data-id="${tData.id}" data-type="${type}" data-week="${week}">Save</button>
                </div>
            `;
            renderInlineItems(`ed-items-${type}-${week}`, tData.items);

            document.getElementById(`ed-add-item-${type}-${week}`).addEventListener("click", () => {
                tData.items.push({particular: "", fundSource: "General", amount: 0});
                renderInlineItems(`ed-items-${type}-${week}`, tData.items);
            });
            editorBox.querySelector(".ed-cancel-btn").addEventListener("click", closeAllEditors);
            editorBox.querySelector(".ed-save-btn").addEventListener("click", async (e) => await saveInlineTemplate(e.target));
        }

        function renderInlineItems(containerId, items) {
            const container = document.getElementById(containerId);
            if(!container) return;

            container.innerHTML = items.map((item, idx) => `
                <div class="row g-1 mb-2 ed-item-row">
                    <div class="col-12"><input type="text" class="form-control inline-input ed-part" value="${escapeHtml(item.particular)}" placeholder="Particular"></div>
                    <div class="col-6"><select class="form-select inline-select ed-fund">${buildFundOptions(item.fundSource)}</select></div>
                    <div class="col-4"><input type="number" step="0.01" class="form-control inline-input text-end ed-amt" value="${item.amount || ''}" placeholder="Amount"></div>
                    <div class="col-2 d-grid"><button type="button" class="btn btn-sm btn-outline-danger ed-del-item"><i class="bi bi-trash"></i></button></div>
                </div>
            `).join("");
            container.querySelectorAll(".ed-del-item").forEach((btn, idx) => {
                btn.addEventListener("click", () => {
                    items.splice(idx, 1);
                    if(items.length === 0) items.push({particular: "", fundSource: "General", amount: 0});
                    renderInlineItems(containerId, items);
                });
            });
        }

        async function saveInlineTemplate(btn) {
            const type = btn.dataset.type;
            const week = parseInt(btn.dataset.week);
            const id = parseInt(btn.dataset.id);

            const ministry = document.getElementById(`ed-min-${type}-${week}`).value;
            const payee = document.getElementById(`ed-pay-${type}-${week}`).value.trim();

            const itemRows = document.getElementById(`ed-items-${type}-${week}`).querySelectorAll(".ed-item-row");
            const items = [];
            itemRows.forEach(row => {
                const p = row.querySelector(".ed-part").value.trim();
                const f = row.querySelector(".ed-fund").value;
                const a = parseMoney(row.querySelector(".ed-amt").value);
                if(p !== "") items.push({ particular: p, fundSource: f, amount: a });
            });

            if(ministry === "" || payee === "" || items.length === 0) {
                showToast("Ministry, Payee, and at least one particular are required.", "warning");
                return;
            }

            btn.disabled = true;
            btn.innerHTML = `<span class="spinner-border spinner-border-sm"></span>`;

            const payload = {
                templateId: id, ministry: ministry, payee: payee,
                recurrenceType: type, weekOfMonth: week, items: items
            };
            try {
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                const response = await fetch("?handler=SaveTemplate", {
                    method: "POST",
                    headers: { "Content-Type": "application/json", "RequestVerificationToken": token || "" },
                    body: JSON.stringify(payload)
                });
                const data = await response.json();
                if (!response.ok || !data.success) {
                    showToast(data?.message || "Failed to save.", "error");
                    btn.disabled = false; btn.innerText = "Save";
                    return;
                }

                await reloadTemplatesFromServer();
                showToast("Schedule updated.", "success");
            } catch(e) {
                showToast("Save failed.", "error");
            }
        }

        async function deleteInlineTemplate(id) {
            try {
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                const response = await fetch("?handler=DeleteTemplate", {
                    method: "POST",
                    headers: { "Content-Type": "application/json", "RequestVerificationToken": token || "" },
                    body: JSON.stringify({ templateId: id })
                });
                const data = await response.json();
                if (data.success) {
                    await reloadTemplatesFromServer();
                    showToast("Voucher removed from schedule.", "success");
                }
            } catch(e) {
                showToast("Delete failed.", "error");
            }
        }

        async function reloadTemplatesFromServer() {
            const reload = await fetch("?handler=Templates");
            const reloadData = await reload.json();
            fixedTemplates = Array.isArray(reloadData?.data) ? reloadData.data : [];
            renderScheduleUI();
        }

        // Event Delegation for the Modal UI
        const templateDash = document.querySelector(".template-dash-container");
        if(templateDash) {
            templateDash.addEventListener("click", (e) => {
                const addBtn = e.target.closest(".add-schedule-voucher-btn");
                if(addBtn) {
                    openEditor(addBtn.dataset.type, parseInt(addBtn.dataset.week), 0);
                    return;
                }

                const editBtn = e.target.closest(".edit-sched-btn");
                if(editBtn) {
                    e.preventDefault();
                    const id = parseInt(editBtn.dataset.id);
                    const t = fixedTemplates.find(x => x.id === id);
                    if(t) openEditor(t.recurrenceType, t.weekOfMonth, id);
                    return;
                }

                const delBtn = e.target.closest(".delete-sched-btn");
                if(delBtn) {
                    e.preventDefault();
                    const id = parseInt(delBtn.dataset.id);
                    document.getElementById("deleteTemplateId").value = id;
                    bootstrap.Modal.getOrCreateInstance(document.getElementById("deleteTemplateModal")).show();
                    return;
                }
            });
        }

        const openTemplateSettingsBtn = document.getElementById("openTemplateSettingsBtn");
        if (openTemplateSettingsBtn) {
            openTemplateSettingsBtn.addEventListener("click", () => {
                renderScheduleUI();
                bootstrap.Modal.getOrCreateInstance(document.getElementById("templateModal")).show();
            });
        }

        const useTemplateBtn = document.getElementById("useTemplateBtn");
        if (useTemplateBtn) {
            useTemplateBtn.addEventListener("click", () => {
                bootstrap.Modal.getOrCreateInstance(document.getElementById("useTemplateModal")).show();
            });
        }

        const applyManualScheduleBtn = document.getElementById("applyManualScheduleBtn");
        if(applyManualScheduleBtn) {
            applyManualScheduleBtn.addEventListener("click", () => {
                const val = document.getElementById("manualLoadSelect").value;
                const parts = val.split("|");
                const type = parts[0];
                const week = parseInt(parts[1]);

                const templates = fixedTemplates.filter(t => t.recurrenceType === type && t.weekOfMonth === week);

                if(templates.length === 0) {
                    showToast("No vouchers configured for this schedule.", "warning");
                    return;
                }

                templates.forEach(t => {
                    sheet.vouchers.push(buildVoucherFromTemplate(t));
                });

                renderVoucherList();
                bootstrap.Modal.getOrCreateInstance(document.getElementById("useTemplateModal")).hide();
                showToast(`Loaded ${templates.length} voucher(s).`, "success");
            });
        }

        // ====================================================
        // VOUCHER RENDERER & LOGIC
        // ====================================================

        function renderVoucherList() {
            const container = document.getElementById("voucherList");
            if (!container) return;

            container.innerHTML = "";

            sheet.vouchers.forEach((voucher, vIndex) => {
                normalizeVoucher(voucher);
                const singleMode = isSingleItemVoucher(voucher);
                const card = document.createElement("div");
                card.className = "voucher-card";
                card.dataset.vindex = vIndex;

                let html = `
                    <div class="voucher-headline">
                        <select class="form-select inline-select voucher-ministry" data-vindex="${vIndex}">
                            ${buildMinistryOptions(voucher.ministry)}
                        </select>
                        <span class="voucher-dash">-</span>
                        <input type="text" class="form-control inline-input voucher-payee fw-bold text-dark" data-vindex="${vIndex}" value="${escapeHtml(voucher.payee)}" placeholder="Payee" />
                    </div>
                `;
                if (singleMode) {
                    const item = voucher.items[0];
                    html += `
                        <div class="voucher-line">
                            <div><input type="text" class="form-control inline-input item-particular" data-vindex="${vIndex}" data-iindex="0" value="${escapeHtml(item.particular)}" placeholder="Particular" /></div>
                            <div><select class="form-select inline-select item-fund-source" data-vindex="${vIndex}" data-iindex="0">${buildFundOptions(item.fundSource)}</select></div>
                            <div><input type="text" class="form-control inline-input field-blank" tabindex="-1" readonly /></div>
                            <div><input type="number" step="0.01" min="0" class="form-control inline-input voucher-total text-end fw-bold" data-vindex="${vIndex}" value="${voucher.totalInput === 0 ? "" : voucher.totalInput}" /></div>
                            <div><input type="text" class="form-control inline-input voucher-number text-end fw-bold" data-vindex="${vIndex}" value="${escapeHtml(voucher.voucherNumber)}" /></div>
                            <div><input type="number" step="0.01" min="0" class="form-control inline-input item-return text-end money-return" data-vindex="${vIndex}" data-iindex="0" value="${item.amountReturned === 0 ? "" : item.amountReturned}" /></div>
                        </div>
                    `;
                } else {
                    voucher.items.forEach((item, iIndex) => {
                        const isLast = iIndex === voucher.items.length - 1;
                        html += `
                            <div class="voucher-line">
                                <div><input type="text" class="form-control inline-input item-particular" data-vindex="${vIndex}" data-iindex="${iIndex}" value="${escapeHtml(item.particular)}" placeholder="Particular" /></div>
                                <div><select class="form-select inline-select item-fund-source" data-vindex="${vIndex}" data-iindex="${iIndex}">${buildFundOptions(item.fundSource)}</select></div>
                                <div><input type="number" step="0.01" min="0" class="form-control inline-input item-amount text-end fw-semibold text-dark" data-vindex="${vIndex}" data-iindex="${iIndex}" value="${item.amount === 0 ? "" : item.amount}" /></div>
                                <div>${isLast ? `<input type="text" class="form-control inline-input field-readonly text-end text-dark" value="${formatMoney(voucherReleasedTotal(voucher))}" readonly />` : `<div></div>`}</div>
                                <div>${isLast ? `<input type="text" class="form-control inline-input voucher-number text-end fw-bold" data-vindex="${vIndex}" value="${escapeHtml(voucher.voucherNumber)}" />` : `<div></div>`}</div>
                                <div><input type="number" step="0.01" min="0" class="form-control inline-input item-return text-end money-return" data-vindex="${vIndex}" data-iindex="${iIndex}" value="${item.amountReturned === 0 ? "" : item.amountReturned}" /></div>
                            </div>
                        `;
                    });
                }

                html += `
                    <div class="voucher-actions">
                        <button type="button" class="btn btn-sm btn-light border fw-semibold text-primary add-item-btn" data-vindex="${vIndex}">+ Add Sub-Item</button>
                        <button type="button" class="btn btn-sm btn-light border fw-semibold text-danger remove-item-btn" data-vindex="${vIndex}"><i class="bi bi-dash-circle"></i> Item</button>
                        <button type="button" class="btn btn-sm btn-danger fw-bold ms-auto remove-voucher-btn" data-vindex="${vIndex}"><i class="bi bi-trash"></i> Remove Voucher</button>
                    </div>
                `;

                card.innerHTML = html;
                container.appendChild(card);
            });

            recalcSummary();
            syncHiddenJson();
        }

        function refreshVoucherComputedFields(vIndex) {
            const voucherCard = document.querySelector(`.voucher-card[data-vindex="${vIndex}"]`);
            if (!voucherCard) return;

            const voucher = sheet.vouchers[vIndex];
            normalizeVoucher(voucher);

            if (!isSingleItemVoucher(voucher)) {
                const lastRowReadonly = voucherCard.querySelector(".field-readonly");
                if (lastRowReadonly) {
                    lastRowReadonly.value = formatMoney(voucherReleasedTotal(voucher));
                }
            }

            syncHiddenJson();
            recalcSummary();
        }

        function recalcSummary() {
            sheet.vouchers.forEach(normalizeVoucher);
            const totalReleased = sheet.vouchers.reduce((sum, voucher) => sum + voucherReleasedTotal(voucher), 0);
            const totalReturned = sheet.vouchers.reduce((sum, voucher) => sum + voucherReturnedTotal(voucher), 0);
            const adjusted = totalReleased - totalReturned;

            const blessingEl = document.getElementById("blessingText");
            const blessing = parseMoney((blessingEl?.textContent || "0").replaceAll(",", ""));
            const netCash = blessing - adjusted;

            document.getElementById("grandTotalText").textContent = formatMoney(totalReleased);
            document.getElementById("grandReturnText").textContent = formatMoney(totalReturned);
            document.getElementById("adjustedDisbursementText").textContent = formatMoney(adjusted);
            document.getElementById("lessDisbursementText").textContent = formatMoney(adjusted);
            const netBox = document.getElementById("netCashBalanceText");
            netBox.textContent = formatMoney(netCash);

            if(netCash < 0) {
                netBox.classList.remove("text-success");
                netBox.classList.add("text-danger");
            } else {
                netBox.classList.remove("text-danger");
                netBox.classList.add("text-success");
            }
        }

        function syncHiddenJson() {
            sheet.vouchers.forEach(normalizeVoucher);
            const hidden = document.getElementById("SheetJson");
            if (hidden) {
                hidden.value = JSON.stringify(sheet);
                if (currentRecordDate) {
                    sessionStorage.setItem(draftKey, hidden.value);
                }
            }
        }

        const addVoucherBtn = document.getElementById("addVoucherBtn");
        if (addVoucherBtn) {
            addVoucherBtn.addEventListener("click", () => {
                sheet.vouchers.push(createEmptyVoucher());
                renderVoucherList();
            });
        }

        const voucherList = document.getElementById("voucherList");
        if (voucherList) {
            voucherList.addEventListener("input", (e) => {
                const target = e.target;
                const vIndex = parseInt(target.dataset.vindex ?? "-1");
                const iIndex = parseInt(target.dataset.iindex ?? "-1");

                if (Number.isNaN(vIndex) || vIndex < 0) return;
                const voucher = sheet.vouchers[vIndex];

                if (target.classList.contains("voucher-payee")) { voucher.payee = target.value; syncHiddenJson(); return; }
                if (target.classList.contains("voucher-number")) { voucher.voucherNumber = target.value; syncHiddenJson(); return; }
                if (target.classList.contains("item-particular")) { voucher.items[iIndex].particular = target.value; syncHiddenJson(); return; }

                if (target.classList.contains("voucher-total")) {
                    voucher.totalInput = target.value === "" ? 0 : parseMoney(target.value);
                    normalizeVoucher(voucher);
                    syncHiddenJson(); recalcSummary(); return;
                }

                if (target.classList.contains("item-amount")) {
                    voucher.items[iIndex].amount = target.value === "" ? 0 : parseMoney(target.value);
                    normalizeVoucher(voucher); refreshVoucherComputedFields(vIndex); return;
                }

                if (target.classList.contains("item-return")) {
                    voucher.items[iIndex].amountReturned = target.value === "" ? 0 : parseMoney(target.value);
                    clampItemReturn(voucher.items[iIndex], voucher); syncHiddenJson(); recalcSummary(); return;
                }
            });
            voucherList.addEventListener("change", (e) => {
                const target = e.target;
                const vIndex = parseInt(target.dataset.vindex ?? "-1");
                const iIndex = parseInt(target.dataset.iindex ?? "-1");

                if (Number.isNaN(vIndex) || vIndex < 0) return;

                if (target.classList.contains("voucher-ministry")) { sheet.vouchers[vIndex].ministry = target.value; syncHiddenJson(); }
                if (target.classList.contains("item-fund-source")) { sheet.vouchers[vIndex].items[iIndex].fundSource = target.value; syncHiddenJson(); }
            });
            voucherList.addEventListener("click", (e) => {
                const target = e.target;
                const vIndex = parseInt(target.dataset.vindex ?? "-1");
                if (Number.isNaN(vIndex) || vIndex < 0) return;

                if (target.classList.contains("add-item-btn")) {
                    sheet.vouchers[vIndex].items.push(createEmptyItem()); renderVoucherList(); return;
                }

                if (target.classList.contains("remove-item-btn") || target.closest(".remove-item-btn")) {
                    if (sheet.vouchers[vIndex].items.length > 1) { sheet.vouchers[vIndex].items.pop(); renderVoucherList(); }
                    return;
                }

                if (target.classList.contains("remove-voucher-btn") || target.closest(".remove-voucher-btn")) {
                    if (sheet.vouchers.length > 1) { sheet.vouchers.splice(vIndex, 1); renderVoucherList(); }
                    return;
                }
            });
        }

        const recordDateInput = document.getElementById("recordDateInput");
        if (recordDateInput) {
            recordDateInput.addEventListener("change", () => {
                window.location.href = `?RecordDate=${encodeURIComponent(recordDateInput.value)}`;
            });
        }

        const sheetForm = document.getElementById("sheetForm");
        const preSaveBtn = document.getElementById("preSaveBtn");

        // ✨ SIMPLIFIED SAVE LOGIC ✨
        if (preSaveBtn && sheetForm) {
            preSaveBtn.addEventListener("click", () => {
                syncHiddenJson();
                recalcSummary();
                sessionStorage.removeItem(draftKey);
                sheetForm.submit();
            });
        }

        const confirmDeleteTemplateBtn = document.getElementById("confirmDeleteTemplateBtn");
        if (confirmDeleteTemplateBtn) {
            confirmDeleteTemplateBtn.addEventListener("click", async () => {
                const id = parseInt(document.getElementById("deleteTemplateId").value);
                if (id > 0) {
                    confirmDeleteTemplateBtn.disabled = true;
                    confirmDeleteTemplateBtn.innerHTML = `<span class="spinner-border spinner-border-sm me-2"></span>Removing...`;
                    await deleteInlineTemplate(id);
                    bootstrap.Modal.getInstance(document.getElementById("deleteTemplateModal")).hide();
                    confirmDeleteTemplateBtn.disabled = false;
                    confirmDeleteTemplateBtn.textContent = "Yes, Remove";
                }
            });
        }

        renderVoucherList();
    })();
</script>

<script>
    (() => {
        const scrollKey = "Disbursement_ScrollPosition";
        let scrollTimeout;

        window.addEventListener("scroll", function () {
            if (!document.querySelector('.disb-page')) return;
            clearTimeout(scrollTimeout);
            scrollTimeout = setTimeout(() => {
                sessionStorage.setItem(scrollKey, window.scrollY);
            }, 50);
        }, { passive: true });

        document.addEventListener("click", (e) => {
            if (!document.querySelector('.disb-page')) return;
            const link = e.target.closest('a');
            if (link && link.href && !link.getAttribute('href').startsWith('#')) {
                sessionStorage.setItem(scrollKey, window.scrollY);
            }
        });

        function forceScroll() {
            const savedScroll = sessionStorage.getItem(scrollKey);
            if (savedScroll) {
                const y = parseInt(savedScroll);
                setTimeout(() => window.scrollTo({ top: y, behavior: "instant" }), 10);
                setTimeout(() => window.scrollTo({ top: y, behavior: "instant" }), 50);
                setTimeout(() => window.scrollTo({ top: y, behavior: "instant" }), 150);
            }
        }

        document.addEventListener("DOMContentLoaded", forceScroll);
        document.body.addEventListener('htmx:afterSettle', function() {
            if (document.querySelector('.disb-page')) forceScroll();
        });
        document.body.addEventListener('htmx:historyRestore', function() {
            if (document.querySelector('.disb-page')) forceScroll();
        });
    })();
</script>