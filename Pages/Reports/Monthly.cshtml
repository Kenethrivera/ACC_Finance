@page
@model acc_finance.Pages.Reports.MonthlyModel
@using acc_finance.Models.Reports
@{
    ViewData["Title"] = "Monthly Financial Report";
}

@functions {
    public string MoneyOrBlank(decimal value)
    {
        return value == 0 ? "-" : value.ToString("N2");
    }
}

<style>
    /* --- GLOBAL & CARDS --- */
    .monthly-page {
        max-width: 1200px;
        margin: 0 auto;
        color: #0f172a;
        font-size: 0.9rem;
        line-height: 1.5;
    }

    .card-modern {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
    }

    .section-title {
        font-size: 1.1rem;
        font-weight: 600;
        color: #0f172a;
        letter-spacing: -0.01em;
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid #e2e8f0;
        text-transform: uppercase;
    }

    .sub-section-title {
        font-size: 0.95rem;
        font-weight: 700;
        color: #334155;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-top: 1.5rem;
        margin-bottom: 0.75rem;
    }

    /* --- TOOLBAR --- */
    .toolbar-form {
        display: flex;
        gap: 12px;
        align-items: flex-end;
        flex-wrap: wrap;
    }

    .form-label {
        font-size: 0.85rem;
        font-weight: 600;
        color: #475569;
        margin-bottom: 4px;
    }

    .form-control-modern {
        font-size: 0.9rem;
        border-radius: 8px;
        border: 1px solid #cbd5e1;
        padding: 0.5rem 0.75rem;
        background: #fff;
    }

        .form-control-modern:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.15);
            outline: none;
        }

    /* --- MODERN TABLES --- */
    .table-modern-wrap {
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        overflow: hidden;
        margin-bottom: 1.5rem;
    }

    .table-modern {
        width: 100%;
        margin-bottom: 0;
        font-size: 0.85rem;
        border-collapse: collapse;
    }

        .table-modern thead th {
            background: #f8fafc;
            color: #475569;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.05em;
            border-bottom: 1px solid #e2e8f0;
            padding: 12px 16px;
            white-space: nowrap;
        }

        .table-modern tbody td {
            background: #ffffff;
            border-bottom: 1px solid #f1f5f9;
            padding: 10px 16px;
            color: #1e293b;
            vertical-align: middle;
        }

        .table-modern tbody tr:last-child td {
            border-bottom: none;
        }

        .table-modern tbody tr:hover td {
            background: #f8fafc;
        }

        .table-modern tfoot td {
            background: #f8fafc;
            border-top: 2px solid #cbd5e1;
            font-weight: 700;
            color: #0f172a;
            padding: 14px 16px;
        }

    /* --- DENOMINATION LISTS --- */
    .clean-list-wrap {
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        background: #fff;
        max-width: 500px;
    }

    .clean-list-row {
        display: flex;
        justify-content: space-between;
        padding: 10px 16px;
        border-bottom: 1px solid #f1f5f9;
        font-size: 0.9rem;
    }

        .clean-list-row:last-child {
            border-bottom: none;
        }

    .clean-list-label {
        font-weight: 600;
        color: #475569;
    }

    .clean-list-amount {
        font-weight: 600;
        color: #0f172a;
    }

    .clean-list-total {
        background: #f8fafc;
        border-top: 2px solid #cbd5e1;
        font-weight: 700;
        color: #0f172a;
    }

    /* --- DISBURSEMENT CUSTOM GRID --- */
    .cash-grid-wrap {
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        background: #fff;
        margin-bottom: 1.5rem;
    }

    .cash-grid-header {
        display: grid;
        grid-template-columns: 2fr 110px 110px 90px 110px;
        gap: 12px;
        background: #f8fafc;
        color: #475569;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.05em;
        padding: 12px 16px;
        border-bottom: 1px solid #e2e8f0;
        border-radius: 8px 8px 0 0;
    }

    .cash-grid-row {
        display: grid;
        grid-template-columns: 2fr 110px 110px 90px 110px;
        gap: 12px;
        padding: 8px 16px;
        font-size: 0.85rem;
        align-items: start;
        border-bottom: 1px solid #f1f5f9;
    }

        .cash-grid-row:last-child {
            border-bottom: none;
        }

        .cash-grid-row.main-row {
            padding-top: 14px;
            font-weight: 600;
            color: #0f172a;
        }

        .cash-grid-row.detail-row {
            padding-top: 4px;
            padding-bottom: 4px;
            color: #475569;
        }

            .cash-grid-row.detail-row .particular-text {
                padding-left: 1.5rem;
            }

    .cash-grid-footer {
        display: grid;
        grid-template-columns: 2fr 110px 110px 90px 110px;
        gap: 12px;
        background: #f8fafc;
        border-top: 2px solid #cbd5e1;
        padding: 14px 16px;
        font-weight: 700;
        font-size: 0.85rem;
        color: #0f172a;
        border-radius: 0 0 8px 8px;
    }

    .cash-return-text {
        color: #dc2626;
    }

    /* --- OLD STYLE SUMMARY DISBURSEMENT REVERT --- */
    .summary-disbursement-report {
        margin-top: 6px;
    }

    .summary-disbursement-head, .summary-group-row, .summary-grand-total-row {
        display: grid;
        grid-template-columns: 1fr 110px 110px;
        gap: 10px;
        align-items: start;
        font-variant-numeric: tabular-nums;
    }

    .summary-disbursement-head {
        font-weight: 700;
        color: #475569;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.05em;
        margin-bottom: 8px;
        padding-bottom: 8px;
        border-bottom: 1px solid #e2e8f0;
    }

    .summary-col-text {
        text-align: left;
    }

    .summary-col-amount, .summary-col-total {
        text-align: right;
    }

    .summary-group-block {
        margin-top: 10px;
    }

    .summary-group-title {
        font-weight: 700;
        color: #0f172a;
        margin-bottom: 4px;
    }

    .summary-group-row {
        padding: 4px 0;
        font-size: 0.85rem;
        color: #475569;
    }

    .summary-label-cell {
        padding-left: 2rem;
    }

    .amount-underline {
        border-bottom: 1px solid #0f172a;
        padding-bottom: 2px;
    }

    .summary-grand-total-row {
        margin-top: 16px;
        padding-top: 12px;
        border-top: 2px solid #cbd5e1;
    }

    .summary-total-label {
        font-weight: 700;
        color: #0f172a;
    }

    .summary-grand-total-amount {
        font-weight: 700;
        color: #0f172a;
    }

    /* --- FINAL SUMMARY --- */
    .final-summary-box {
        background: #f8fafc;
        border: 1px solid #cbd5e1;
        border-radius: 8px;
        padding: 20px;
        max-width: 600px;
    }

    .final-summary-row {
        display: flex;
        justify-content: space-between;
        padding: 8px 0;
        font-size: 0.95rem;
        color: #334155;
    }

    .final-summary-net {
        display: flex;
        justify-content: space-between;
        padding-top: 16px;
        margin-top: 8px;
        border-top: 2px solid #94a3b8;
        font-size: 1.1rem;
        font-weight: 800;
    }

    .net-positive {
        color: #15803d;
    }

    .net-negative {
        color: #dc2626;
    }

    /* --- PRINT STYLES --- */
    @@media print {
        .monthly-topbar, .navbar, .sidebar, footer {
            display: none !important;
        }

        .monthly-page {
            max-width: none;
            padding: 0;
        }

        .card-modern {
            border: none;
            box-shadow: none;
            border-radius: 0;
            page-break-after: always;
            margin-bottom: 0;
        }

            .card-modern:last-child {
                page-break-after: auto;
            }

        .table-modern-wrap, .clean-list-wrap, .cash-grid-wrap {
            border: 1px solid #000;
            border-radius: 0;
        }

        .table-modern thead th, .cash-grid-header, .summary-disbursement-head {
            background: #f1f5f9 !important;
            border-bottom: 1px solid #000;
            -webkit-print-color-adjust: exact;
        }

        .summary-grand-total-row {
            border-top: 2px solid #000;
        }
    }

    @@media (max-width: 900px) {
        .cash-grid-header, .cash-grid-row, .cash-grid-footer {
            grid-template-columns: 1.6fr 90px 90px 80px 90px;
            gap: 8px;
        }

        .summary-disbursement-head, .summary-group-row, .summary-grand-total-row {
            grid-template-columns: 1fr 80px 80px;
        }
    }
</style>

<div class="monthly-page py-4">

    <div class="card card-modern mb-4 border-0 shadow-sm">
        <div class="card-body p-4">
            <form id="toolbarForm" method="get" class="row g-3 align-items-end">
                <div class="col-12 col-lg-auto">
                    <label asp-for="SelectedMonth" class="form-label text-muted fw-bold text-uppercase mb-2" style="font-size: 0.75rem; letter-spacing: 0.05em;">Select Month</label>
                    <div class="input-group shadow-sm" style="border-radius: 8px;">
                        <input asp-for="SelectedMonth" type="month" class="form-control border-secondary border-opacity-25" style="max-width: 220px;" />
                        <button type="submit" class="btn btn-primary fw-semibold px-4">
                            Load Data
                        </button>
                    </div>
                </div>

                <div class="col-12 col-lg-auto ms-lg-auto">
                    <label class="form-label text-muted fw-bold text-uppercase mb-2" style="font-size: 0.75rem; letter-spacing: 0.05em;">Google Sheets Exports</label>
                    <div class="d-flex gap-2 flex-wrap">
                        <button type="submit" name="handler" value="Export" class="btn btn-light border border-secondary border-opacity-25 shadow-sm fw-bold text-success px-3" style="border-radius: 8px; font-size: 0.85rem;">
                            <i class="bi bi-file-earmark-spreadsheet me-1"></i> DETAILED
                        </button>

                        <button type="submit" name="handler" value="ExportFinancial" class="btn btn-light border border-secondary border-opacity-25 shadow-sm fw-bold text-dark px-3" style="border-radius: 8px; font-size: 0.85rem;">
                            <i class="bi bi-file-earmark-bar-graph me-1"></i> FINANCIAL
                        </button>

                        <button type="submit" name="handler" value="Explain" class="btn btn-light border border-primary border-opacity-50 shadow-sm text-primary px-3" style="border-radius: 8px;" title="Check Report with AI">
                            <i class="bi bi-stars"></i>
                        </button>

                        @if (User.IsInRole("admin") || User.IsInRole("Admin"))
                        {
                            <button type="button" class="btn btn-light border border-secondary border-opacity-25 shadow-sm text-secondary px-3" style="border-radius: 8px;" title="Sheet Settings" data-bs-toggle="modal" data-bs-target="#settingsModal">
                                <i class="bi bi-gear-fill"></i>
                            </button>
                        }
                    </div>
                </div>
            </form>
        </div>
        <div class="card-footer bg-light border-top-0 py-2 px-4" style="border-radius: 0 0 12px 12px;">
            <span class="text-muted" style="font-size: 0.85rem;">
                <i class="bi bi-calendar3 me-1"></i> Showing finalized records for <strong class="text-dark">@Model.MonthReport.MonthLabel</strong>
            </span>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.AiSummary))
    {
        <div class="card mb-4 border-primary shadow-sm" id="aiReportCard" style="background-color: #f8fafc; border-left: 4px solid #3b82f6 !important;">
            <div class="card-body p-4">

                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0" style="color: #0f172a; text-transform: uppercase;">
                        <i class="bi bi-google text-primary me-2"></i> GEMINI FINANCIAL REPORT CHECKER
                    </h5>
                    <button type="button" class="btn-close" aria-label="Close" onclick="document.getElementById('aiReportCard').style.display='none';"></button>
                </div>

                <!-- Enhanced AI Auditor Disclaimer -->
                <div class="alert alert-info mb-4 border-info shadow-sm" style="font-size: 0.85rem; border-radius: 12px; background-color: #f0f9ff;">
                    <div class="d-flex align-items-start">
                        <i class="bi bi-shield-shaded fs-3 me-3 text-primary"></i>
                        <div>
                            <h6 class="fw-bold text-dark mb-1">Audit Protocol & Data Security</h6>
                            <p class="mb-2 text-dark">
                                This report is generated by <strong>Gemini 2.5 Flash</strong> acting as an external Independent Assistant.
                                To ensure 100% accuracy and privacy, we have implemented a <strong>Zero-PII & Deterministic Math</strong> framework:
                            </p>
                            <ul class="mb-2 text-muted" style="padding-left: 1.2rem;">
                                <li><strong>Privacy:</strong> All names and sensitive identifiers are stripped locally. The AI only sees generic fund labels and numbers.</li>
                                <li><strong>Math Integrity:</strong> Calculations are performed by our C# backend. The AI is used to <strong>verify the logical consistency</strong> of those results, not to calculate them from scratch, eliminating the risk of "AI hallucinations" in your totals.</li>
                                <li><strong>Purpose:</strong> By using an external AI to judge the system's output, we provide a second layer of verification to ensure the narrative explanation matches the underlying ledger data.</li>
                            </ul>
                            <span class="badge bg-primary-subtle text-primary border border-primary-subtle">Verified Deterministic Flow</span>
                        </div>
                    </div>
                </div>

                <!-- AI Output (Rendered as Raw HTML to show Tables) -->
                <div class="ai-report-content" style="color: #334155; font-size: 0.95rem; line-height: 1.6;">
                    @Html.Raw(Model.AiSummary)
                </div>
            </div>
        </div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.Message))
    {
        @if (Model.Message.StartsWith("==="))
        {
            <pre class="bg-dark text-light p-3 rounded mb-4" style="font-size: 12px; max-height: 400px; overflow-y: auto;">@Model.Message</pre>
        }
        else
        {
            <div class="alert alert-warning border-warning rounded mb-4">@Model.Message</div>
        }
    }

    @foreach (var page in Model.MonthReport.Pages)
    {
        <div class="card card-modern mb-5">
            <div class="card-body p-5">

                <div class="text-center mb-5 border-bottom pb-4">
                    <h2 class="fw-bold mb-1" style="color: #0f172a; letter-spacing: 0.05em; text-transform: uppercase;">Adelina Christian Church</h2>
                    <h4 class="fw-semibold text-muted mb-2" style="font-size: 1.1rem; letter-spacing: 0.05em; text-transform: uppercase;">Financial Report</h4>
                    <div class="text-primary fw-bold fs-5">@(@page.ReportDate.ToString("MMMM dd, yyyy"))</div>
                </div>

                @if (!page.HasReport)
                {
                    <div class="empty-panel-note" style="padding: 16px 0; text-align: center; border: 1px dashed #cbd5e1; border-radius: 8px; background: #f8fafc; color: #64748b;">
                        <i class="bi bi-info-circle me-1"></i> No finalized records found for this date.
                    </div>
                }
                else
                {
                    <div class="mb-5">
                        <h4 class="section-title">
                            Sources of Blessings
                            @if (!string.IsNullOrWhiteSpace(page.Report.Giving.RecordCode))
                            {
                                <span class="text-muted fs-6 fw-normal ms-2">Ref: @(@page.Report.Giving.RecordCode)</span>
                            }
                        </h4>

                        <div class="table-modern-wrap" id="giving-@(@page.ReportDate.ToString("yyyy-MM-dd"))">
                            <table class="table-modern">
                                <thead>
                                    <tr>
                                        <th class="text-start">Name</th>
                                        <th class="text-end">Tithes</th>
                                        <th class="text-end">Offerings</th>
                                        <th class="text-end">Solomon</th>
                                        <th class="text-end">Noah</th>
                                        <th class="text-end">Mission</th>
                                        <th class="text-end">Others</th>
                                        <th class="text-end">Total</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (page.Report.Giving.Rows != null && page.Report.Giving.Rows.Any())
                                    {
                                        @foreach (var row in page.Report.Giving.Rows)
                                        {
                                            <tr>
                                                <td class="text-start fw-semibold">@row.Name</td>
                                                <td class="text-end text-muted">@MoneyOrBlank(row.Tithes)</td>
                                                <td class="text-end text-muted">@MoneyOrBlank(row.Offerings)</td>
                                                <td class="text-end text-muted">@MoneyOrBlank(row.Solomon)</td>
                                                <td class="text-end text-muted">@MoneyOrBlank(row.Noah)</td>
                                                <td class="text-end text-muted">@MoneyOrBlank(row.Mission)</td>
                                                <td class="text-end text-muted">@MoneyOrBlank(row.Others)</td>
                                                <td class="text-end fw-bold text-dark">@MoneyOrBlank(row.Total)</td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr><td colspan="8" class="text-center text-muted py-4">No entries found.</td></tr>
                                    }
                                </tbody>
                                <tfoot>
                                    <tr>
                                        <td class="text-start">GRAND TOTAL</td>
                                        <td class="text-end">@(@page.Report.Giving.TotalTithes.ToString("N2"))</td>
                                        <td class="text-end">@(@page.Report.Giving.TotalOfferings.ToString("N2"))</td>
                                        <td class="text-end">@(@page.Report.Giving.TotalSolomon.ToString("N2"))</td>
                                        <td class="text-end">@(@page.Report.Giving.TotalNoah.ToString("N2"))</td>
                                        <td class="text-end">@(@page.Report.Giving.TotalMission.ToString("N2"))</td>
                                        <td class="text-end">@(@page.Report.Giving.TotalOthers.ToString("N2"))</td>
                                        <td class="text-end fs-6">@(@page.Report.Giving.GrandTotal.ToString("N2"))</td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>

                    <div class="mb-5">
                        <h4 class="section-title">Denomination Verified</h4>
                        @if (page.Report.Denomination.Exists && page.Report.Denomination.Lines.Any())
                        {
                            <div class="clean-list-wrap">
                                @foreach (var line in page.Report.Denomination.Lines)
                                {
                                    <div class="clean-list-row">
                                        <div class="clean-list-label">@line.Label <span class="text-muted fw-normal mx-2">×</span> @line.Quantity</div>
                                        <div class="clean-list-amount">@line.LineTotal.ToString("N2")</div>
                                    </div>
                                }
                                <div class="clean-list-row clean-list-total">
                                    <div>TOTAL VERIFIED</div>
                                    <div>@(@page.Report.Denomination.Total.ToString("N2"))</div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="empty-panel-note" style="padding: 16px 0; text-align: center; border: 1px dashed #cbd5e1; border-radius: 8px; background: #f8fafc; color: #64748b;">
                                No denomination data attached to this record.
                            </div>
                        }
                    </div>

                    <div class="mb-5">
                        <h4 class="section-title">Disbursements</h4>

                        @if (page.Report.Disbursement.Vouchers != null && page.Report.Disbursement.Vouchers.Any())
                        {
                            <h5 class="sub-section-title">Cash Disbursements</h5>
                            <div class="cash-grid-wrap" id="disb-@(@page.ReportDate.ToString("yyyy-MM-dd"))">
                                <div class="cash-grid-header">
                                    <div>Particulars</div>
                                    <div class="text-end">Amount</div>
                                    <div class="text-end">Total</div>
                                    <div class="text-center">Voucher #</div>
                                    <div class="text-end">Return</div>
                                </div>

                                @foreach (var voucher in page.Report.Disbursement.Vouchers)
                                {
                                    var lines = voucher.Lines ?? new List<acc_finance.Models.Reports.DisbursementLineVm>();
                                    if (lines.Any())
                                    {
                                        @for (int i = 0; i < lines.Count; i++)
                                        {
                                            var line = lines[i];
                                            bool isLast = i == lines.Count - 1;
                                            bool isSingle = lines.Count == 1;
                                            bool isFirst = i == 0;

                                            if (isFirst)
                                            {
                                                <div class="cash-grid-row main-row border-bottom-0 pb-1">
                                                    <div>@voucher.Ministry - @voucher.Payee</div>
                                                    <div></div><div></div><div></div><div></div>
                                                </div>
                                            }

                                            <div class="cash-grid-row detail-row @(isLast ? "border-bottom" : "border-bottom-0 pb-1")">
                                                <div class="particular-text">@line.Particular</div>
                                                <div class="text-end text-dark fw-semibold">
                                                    @if (!isSingle)
                                                    {
                                                        @line.AmountReleased.ToString("N2")
                                                    }
                                                </div>
                                                <div class="text-end fw-bold text-dark">
                                                    @if (isSingle || isLast)
                                                    {
                                                        @voucher.VoucherTotalReleased.ToString("N2")
                                                    }
                                                </div>
                                                <div class="text-center text-muted">
                                                    @if (isSingle || isLast)
                                                    {
                                                        @voucher.VoucherNumber
                                                    }
                                                </div>
                                                <div class="text-end cash-return-text fw-semibold">
                                                    @if (line.CashReturned > 0)
                                                    {
                                                        @line.CashReturned.ToString("N2")
                                                    }
                                                </div>
                                            </div>
                                        }
                                    }
                                }

                                <div class="cash-grid-footer">
                                    <div>TOTAL DISBURSED & RETURNED</div>
                                    <div></div>
                                    <div class="text-end">@(@page.Report.Disbursement.TotalReleased.ToString("N2"))</div>
                                    <div></div>
                                    <div class="text-end cash-return-text">@(@page.Report.Disbursement.TotalReturned.ToString("N2"))</div>
                                </div>
                            </div>

                            <div class="clean-list-wrap mb-4">
                                <div class="clean-list-row clean-list-total">
                                    <div>ADJUSTED NET DISBURSEMENT</div>
                                    <div>@(@page.Report.Disbursement.TotalNetDisbursement.ToString("N2"))</div>
                                </div>
                            </div>

                            <h5 class="sub-section-title mt-5">Summary Disbursement</h5>
                            <div class="cash-grid-wrap p-4" style="max-width: 600px;">
                                <div class="summary-disbursement-report">
                                    <div class="summary-disbursement-head">
                                        <div class="summary-col-text">Summary</div>
                                        <div class="summary-col-amount text-end">Amount</div>
                                        <div class="summary-col-total text-end">Total</div>
                                    </div>

                                    @foreach (var group in page.Report.Disbursement.Groups)
                                    {
                                        var lines = group.Lines ?? new List<acc_finance.Models.Reports.DisbursementLineVm>();
                                        bool isSingle = lines.Count == 1;

                                        <div class="summary-group-block">
                                            <div class="summary-group-title">@group.Ministry Expenses</div>

                                            @for (int i = 0; i < lines.Count; i++)
                                            {
                                                var line = lines[i];
                                                bool isLast = i == lines.Count - 1;

                                                <div class="summary-group-row">
                                                    <div class="summary-col-text summary-label-cell">
                                                        @line.SummaryLabel
                                                    </div>

                                                    <div class="summary-col-amount text-end @(isLast && !isSingle ? "amount-underline" : "")">
                                                        @if (!isSingle)
                                                        {
                                                            @line.NetAmount.ToString("N2")
                                                        }
                                                    </div>

                                                    <div class="summary-col-total text-end fw-semibold text-dark">
                                                        @if (isSingle || isLast)
                                                        {
                                                            @group.GroupTotal.ToString("N2")
                                                        }
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }

                                    <div class="summary-grand-total-row">
                                        <div class="summary-col-text summary-total-label">TOTAL</div>
                                        <div class="summary-col-amount"></div>
                                        <div class="summary-col-total text-end summary-grand-total-amount fs-6">
                                            @(@page.Report.Disbursement.TotalNetDisbursement.ToString("N2"))
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="empty-panel-note" style="padding: 16px 0; text-align: center; border: 1px dashed #cbd5e1; border-radius: 8px; background: #f8fafc; color: #64748b;">
                                No disbursement data for this date.
                            </div>
                        }
                    </div>

                    <div>
                        <h4 class="section-title">Overall Summary</h4>
                        <div class="final-summary-box">
                            <div class="final-summary-row">
                                <span class="fw-semibold">Total Cash Receipts / Blessings</span>
                                <span class="fw-bold text-dark">@(@page.Report.Summary.CashReceiptsOrBlessings.ToString("N2"))</span>
                            </div>
                            <div class="final-summary-row">
                                <span class="fw-semibold">Less: Total Cash Disbursements</span>
                                <span class="fw-bold text-dark">@(@page.Report.Summary.LessCashDisbursements.ToString("N2"))</span>
                            </div>

                            <div class="final-summary-net @(page.Report.Summary.NetCashBalance < 0 ? "net-negative" : page.Report.Summary.NetCashBalance > 0 ? "net-positive" : "")">
                                <span>NET CASH BALANCE</span>
                                <span>@(@page.Report.Summary.NetCashBalance.ToString("N2"))</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

    <!-- MONTHLY GRAND SUMMARY -->
