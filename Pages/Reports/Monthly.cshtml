<script>
    (() => {
        const scrollKey = "MonthlyReport_ScrollPosition";

        // ==========================================
        // 1. THE MEMORY LEAK FIX (Guard Clauses)
        // ==========================================

        // Continually save the scroll position ONLY when looking at the Monthly Report!
        let scrollTimeout;
        window.addEventListener("scroll", function () {
            // 🚨 CRITICAL FIX: Stop tracking if we navigated to a different HTMX page!
            if (!document.querySelector('.monthly-page')) return;

            clearTimeout(scrollTimeout);
            scrollTimeout = setTimeout(() => {
                sessionStorage.setItem(scrollKey, window.scrollY);
            }, 50);
        }, { passive: true });

        // Save scroll when navigating away manually
        document.addEventListener("click", (e) => {
            if (!document.querySelector('.monthly-page')) return;

            const link = e.target.closest('a');
            if (link && link.href && !link.getAttribute('href').startsWith('#')) {
                sessionStorage.setItem(scrollKey, window.scrollY);
            }
        });

        // ==========================================
        // 2. AGGRESSIVE SCROLL LOCK
        // ==========================================
        function forceScroll() {
            const savedScroll = sessionStorage.getItem(scrollKey);
            if (savedScroll) {
                const y = parseInt(savedScroll);
                // Override HTMX's native scroll-to-top by firing multiple times instantly
                setTimeout(() => window.scrollTo({ top: y, behavior: "instant" }), 10);
                setTimeout(() => window.scrollTo({ top: y, behavior: "instant" }), 50);
                setTimeout(() => window.scrollTo({ top: y, behavior: "instant" }), 150);
            }
        }

        // ==========================================
        // 3. MAIN INITIALIZER
        // ==========================================
        function initializeMonthlyReport() {
            const monthInput = document.getElementById("SelectedMonth");
            const currentMonth = monthInput ? monthInput.value : "default";

            const aiStateKey = "MonthlyReport_AiOpen_" + currentMonth;
            const aiHtmlKey = "MonthlyReport_AiHtml_" + currentMonth;

            // --- A. SILENT AI RESTORATION ---
            const wantsAiOpen = sessionStorage.getItem(aiStateKey) === "true";
            const existingAiCard = document.querySelector(".ai-report-content");

            if (existingAiCard) {
                sessionStorage.setItem(aiHtmlKey, existingAiCard.closest('.card').outerHTML);
                sessionStorage.setItem(aiStateKey, "true");
            }
            else if (wantsAiOpen) {
                const savedHtml = sessionStorage.getItem(aiHtmlKey);
                const toolbarCard = document.querySelector('.card-modern');

                if (toolbarCard && savedHtml) {
                    // Inject instantly
                    toolbarCard.insertAdjacentHTML('afterend', savedHtml);

                    // Background Sync
                    const fetchUrl = new URL(window.location.href);
                    fetchUrl.searchParams.set("handler", "Explain");

                    fetch(fetchUrl.toString())
                        .then(res => res.text())
                        .then(html => {
                            const parser = new DOMParser();
                            const doc = parser.parseFromString(html, 'text/html');
                            const fetchedAiContent = doc.querySelector('.ai-report-content');

                            if (fetchedAiContent) {
                                const newCard = fetchedAiContent.closest('.card');
                                const oldCard = document.querySelector(".ai-report-content").closest('.card');
                                if (oldCard && newCard) {
                                    oldCard.replaceWith(newCard);
                                    sessionStorage.setItem(aiHtmlKey, newCard.outerHTML);
                                }
                            }
                        }).catch(() => {});
                }
            }

            // --- B. TOOLBAR SUBMISSION HANDLING ---
            const topbarForm = document.getElementById("toolbarForm");
            if (topbarForm) {
                topbarForm.replaceWith(topbarForm.cloneNode(true));
                const newForm = document.getElementById("toolbarForm");

                const isAdmin = @Json.Serialize(User.IsInRole("admin") || User.IsInRole("Admin"));

                newForm.addEventListener("submit", function (e) {
                    const clickedButton = e.submitter;

                    if (clickedButton && (clickedButton.value === "Export" || clickedButton.value === "ExportFinancial" || clickedButton.value === "DebugExport")) {
                        if (!isAdmin) {
                            e.preventDefault(); // Stop the form from submitting!

                            // Pop the modal
                            const modal = new bootstrap.Modal(document.getElementById('accessDeniedModal'));
                            modal.show();
                            return; // Exit out so the loading screen doesn't trigger
                        }
                    }

                    // If they are an admin, proceed as normal...
                    const overlay = document.getElementById("loading-overlay");
                    const mainText = document.getElementById("loadingMainText");
                    const subText = document.getElementById("loadingSubText");

                    if (overlay) overlay.classList.add("show");

                    if (clickedButton && clickedButton.value === "Explain") {
                        sessionStorage.setItem(aiStateKey, "true");
                        mainText.innerText = "Generating AI Summary...";
                        subText.innerHTML = "The AI Assistant is reviewing the financial data and writing a summary.<br><strong class='text-primary mt-2 d-block'>Please wait.</strong>";
                    }
                    else if (clickedButton && (clickedButton.value === "Export" || clickedButton.value === "ExportFinancial")) {
                        mainText.innerText = clickedButton.value === "Export" ? "Exporting Detailed Report..." : "Exporting Financial Report...";
                        subText.innerHTML = "This process requires multiple API calls and writing data directly to Google Sheets.<br><strong class='text-danger fs-5 mt-2 d-block'>Please wait and DO NOT refresh the page.</strong>";

                        document.cookie = "DownloadComplete=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;";
                        let downloadTimer = window.setInterval(function() {
                            if (document.cookie.indexOf("DownloadComplete=1") !== -1) {
                                if (overlay) overlay.classList.remove("show");
                                document.cookie = "DownloadComplete=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/;";
                                window.clearInterval(downloadTimer);
                            }
                        }, 500);
                    }
                    else {
                        sessionStorage.removeItem(aiStateKey);
                        mainText.innerText = "Fetching Month Data...";
                        subText.innerHTML = "Please wait. This may take a moment.";
                    }
                });
            }

            // --- C. WIKI HOVER CARD LOGIC ---
            const hoverCard = document.getElementById('wikiHoverCard');
            const cardBody = document.getElementById('wikiHoverCardBody');
            const cardLink = document.getElementById('wikiHoverCardLink');
            let hideTimeout;

            if (hoverCard) {
                const existingCards = document.querySelectorAll('.wiki-hover-card');
                if (existingCards.length > 1) existingCards[0].remove();

                document.body.appendChild(hoverCard);

                window.addEventListener("pagehide", () => {
                    if(hoverCard.parentNode) hoverCard.remove();
                });

                document.addEventListener("click", (e) => {
                    const link = e.target.closest('a');
                    if (link && link.href && !link.getAttribute('href').startsWith('#') && hoverCard.parentNode) {
                        hoverCard.remove();
                    }
                });

                document.addEventListener("mouseover", function (e) {
                    const trigger = e.target.closest('.audit-hover-trigger');
                    const isHoveringCard = e.target.closest('.wiki-hover-card');

                    if (trigger || isHoveringCard) clearTimeout(hideTimeout);

                    if (trigger) {
                        const targetId = trigger.getAttribute('data-target');
                        const targetEl = document.getElementById(targetId);
                        cardLink.innerHTML = "Jump to section &rarr;";

                        if (targetEl) {
                            let previewHtml = "";
                            if (targetId.startsWith('giving')) {
                                const tfoot = targetEl.querySelector('tfoot');
                                if (tfoot) previewHtml = `<table class="table-modern m-0" style="width:100%"><tfoot>${tfoot.innerHTML}</tfoot></table>`;
                            } else if (targetId.startsWith('disb')) {
                                const footer = targetEl.querySelector('.cash-grid-footer');
                                if (footer) previewHtml = `<div class="cash-grid-wrap m-0"><div class="cash-grid-footer" style="padding: 12px; font-size: 0.8rem;">${footer.innerHTML}</div></div>`;
                            }

                            if (previewHtml) {
                                cardBody.innerHTML = previewHtml;
                                cardLink.href = "#" + targetId;
                                showAndPositionPopup(trigger);
                            }
                        } else if (targetId === 'wallet-dashboard') {
                            const row = trigger.closest('tr');
                            const fundName = row.cells[0].textContent.trim();
                            const balanceText = row.cells[4].innerText.replace('Deficit', '').trim();
                            const isDeficit = balanceText.includes('-');

                            let icon = "bi-wallet2", color = "#3b82f6";
                            if (fundName.toLowerCase().includes("pledge")) { icon = "bi-journal-check"; color = "#f59e0b"; }
                            else if (fundName.toLowerCase().includes("const")) { icon = "bi-tools"; color = "#0ea5e9"; }
                            else if (fundName.toLowerCase().includes("worship")) { icon = "bi-music-note-beamed"; color = "#22c55e"; }

                            let textColor = isDeficit ? "#ef4444" : "#0f172a";
                            let cashOnHand = isDeficit ? "0.00" : balanceText;

                            cardBody.innerHTML = `
                                <div style="padding: 24px; background: #fff; border-radius: 0 0 8px 8px; border-top: 4px solid ${color};">
                                    <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 20px;">
                                        <div style="width: 48px; height: 48px; border-radius: 12px; background: ${color}15; color: ${color}; display: flex; align-items: center; justify-content: center; font-size: 1.4rem;">
                                            <i class="bi ${icon}"></i>
                                        </div>
                                        <div>
                                            <div style="font-weight: 800; color: #0f172a; font-size: 1.1rem; line-height: 1.2;">${fundName}</div>
                                            <div style="font-size: 0.7rem; color: #64748b; font-weight: 600; margin-top: 2px;"><i class="bi bi-display"></i> DASHBOARD PREVIEW</div>
                                        </div>
                                    </div>
                                    <div style="margin-bottom: ${isDeficit ? '12px' : '20px'};">
                                        <div style="font-size: 0.75rem; color: #64748b; font-weight: 700; letter-spacing: 0.05em; margin-bottom: 4px;">BOOK BALANCE</div>
                                        <div style="font-size: 2.2rem; font-weight: 800; color: ${textColor}; line-height: 1; font-variant-numeric: tabular-nums;">
                                            <span style="font-size: 1.4rem; color: #94a3b8; font-weight: 600; margin-right: 4px;">₱</span>${balanceText}
                                        </div>
                                    </div>
                                    ${isDeficit ? `
                                    <div style="background: #ecfdf5; border: 1px solid #a7f3d0; color: #16a34a; font-size: 0.75rem; padding: 4px 8px; border-radius: 4px; display: inline-block; font-weight: 700; margin-bottom: 16px;">
                                        <i class="bi bi-arrow-down-left me-1"></i> SUBSIDIZED + ₱ ${balanceText.replace('-', '').trim()}
                                    </div>` : ''}
                                    <div style="border: 1px solid #e2e8f0; border-radius: 8px; padding: 14px; background: #f8fafc;">
                                        <div style="font-size: 0.75rem; color: #64748b; font-weight: 700; letter-spacing: 0.05em; margin-bottom: 4px;">CASH ON HAND</div>
                                        <div style="font-size: 1.4rem; font-weight: 800; color: #0f172a; line-height: 1;">
                                            <span style="font-size: 1rem; color: #94a3b8; font-weight: 600; margin-right: 4px;">₱</span>${cashOnHand}
                                        </div>
                                    </div>
                                </div>
                            `;
                            cardLink.innerHTML = "Go to Dashboard &rarr;";
                            cardLink.href = "/";
                            showAndPositionPopup(trigger);
                        }
                    }
                });

                document.addEventListener("mouseout", function (e) {
                    if (e.target.closest('.audit-hover-trigger') || e.target.closest('.wiki-hover-card')) {
                        hideTimeout = setTimeout(() => hoverCard.classList.remove('show'), 300);
                    }
                });

                function showAndPositionPopup(triggerElement) {
                    hoverCard.classList.add('show');
                    const rect = triggerElement.getBoundingClientRect();
                    let leftPos = rect.right - hoverCard.offsetWidth;
                    if (leftPos < 10) leftPos = 10;
                    hoverCard.style.left = (leftPos + window.scrollX) + 'px';
                    hoverCard.style.top = (rect.bottom + 8 + window.scrollY) + 'px';
                }
            }
        }

        // ==========================================
        // 4. HTMX & BROWSER LIFECYCLE HOOKS
        // ==========================================

        // Normal browser load
        document.addEventListener("DOMContentLoaded", () => {
            initializeMonthlyReport();
            forceScroll();
        });

        // When HTMX injects new HTML
        document.body.addEventListener('htmx:afterSettle', function(event) {
            if (document.querySelector('.monthly-page')) {
                initializeMonthlyReport();
                forceScroll();
            }
        });

        // When user hits browser Back/Forward
        document.body.addEventListener('htmx:historyRestore', function(event) {
            if (document.querySelector('.monthly-page')) forceScroll();
        });

    })();
</script>