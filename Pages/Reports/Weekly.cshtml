@page
@model acc_finance.Pages.Reports.WeeklyModel
@using acc_finance.Models.Reports
@{
    ViewData["Title"] = "Weekly Financial Report";
}

<style>
    .report-page {
        max-width: 1150px;
        margin: 0 auto;
        padding: 24px;
        color: #1f2937;
        font-size: 14px;
        line-height: 1.5;
    }

    .report-shell {
        background: #fff;
        border: 1px solid #d8dee9;
        border-radius: 16px;
        box-shadow: 0 10px 30px rgba(15, 23, 42, 0.06);
        overflow: hidden;
    }

    .report-topbar {
        padding: 16px 22px;
        border-bottom: 1px solid #e5e7eb;
        background: #f8fafc;
    }

    .report-filter-form {
        display: flex;
        gap: 12px;
        align-items: end;
        flex-wrap: wrap;
    }

    .report-filter-group {
        display: flex;
        flex-direction: column;
        gap: 6px;
        min-width: 220px;
    }

        .report-filter-group label {
            font-size: 13px;
            font-weight: 600;
            color: #334155;
        }

        .report-filter-group input[type="date"] {
            border: 1px solid #cbd5e1;
            border-radius: 10px;
            padding: 10px 12px;
            font-size: 14px;
            background: #fff;
        }

    .btn-report-load {
        border: 0;
        border-radius: 10px;
        padding: 10px 18px;
        font-size: 14px;
        font-weight: 600;
        background: #1d4ed8;
        color: white;
        cursor: pointer;
    }

        .btn-report-load:hover {
            background: #1e40af;
        }

    .report-content {
        padding: 30px 34px 38px;
        background: #ffffff;
    }

    .report-header {
        text-align: center;
        margin-bottom: 28px;
    }

    .church-name {
        font-size: 26px;
        font-weight: 800;
        letter-spacing: .5px;
        margin-bottom: 4px;
        color: #0f172a;
        text-transform: uppercase;
    }

    .report-title {
        font-size: 18px;
        font-weight: 700;
        letter-spacing: .4px;
        color: #334155;
        text-transform: uppercase;
    }

    .report-section {
        margin-top: 28px;
    }

    .report-section-title {
        font-size: 16px;
        font-weight: 800;
        color: #111827;
        text-transform: uppercase;
        letter-spacing: .4px;
        margin-bottom: 12px;
        padding-bottom: 6px;
        border-bottom: 2px solid #111827;
    }

    .report-empty,
    .report-message {
        padding: 14px 16px;
        border-radius: 12px;
        background: #fff7ed;
        border: 1px solid #fdba74;
        color: #9a3412;
        margin-bottom: 18px;
    }

    .giving-table-wrap {
        overflow-x: hidden;
    }

    .giving-table {
        width: 100%;
        table-layout: fixed;
        border-collapse: collapse;
        border: 1px solid #cbd5e1;
    }

        .giving-table th,
        .giving-table td {
            overflow: hidden;
        }

            .giving-table th:first-child,
            .giving-table td:first-child {
                width: 30%;
                white-space: nowrap;
            }

            .giving-table th:not(:first-child),
            .giving-table td:not(:first-child) {
                width: 10%;
                white-space: nowrap;
            }

        .giving-table .text-right {
            text-align: right;
            font-variant-numeric: tabular-nums;
            overflow: visible;
            text-overflow: clip;
        }

        .giving-table .name-cell {
            font-weight: 600;
            white-space: nowrap;
            overflow: visible;
            text-overflow: clip;
        }

        .giving-table thead th {
            background: #f1f5f9;
            color: #0f172a;
            font-weight: 800;
            font-size: 13px;
            text-transform: uppercase;
            border: 1px solid #cbd5e1;
            padding: 10px 10px;
            white-space: nowrap;
        }

        .giving-table tbody td {
            border: 1px solid #dbe2ea;
            padding: 9px 10px;
            vertical-align: middle;
        }

        .giving-table .text-right {
            text-align: right;
            font-variant-numeric: tabular-nums;
        }

        .giving-table .text-left {
            text-align: left;
        }

        .giving-table .total-row td {
            font-weight: 800;
            background: #f8fafc;
        }

    .name-cell {
        font-weight: 600;
    }

    .name-chip-family {
        display: inline-block;
        background: #fef3c7;
        color: #92400e;
        border-radius: 999px;
        padding: 2px 9px;
        font-size: 12px;
        font-weight: 700;
        margin-left: 8px;
    }

    .name-chip-group {
        display: inline-block;
        background: #dbeafe;
        color: #1d4ed8;
        border-radius: 999px;
        padding: 2px 9px;
        font-size: 12px;
        font-weight: 700;
        margin-left: 8px;
    }

    .denom-box {
        border: 1px solid #dbe2ea;
        border-radius: 14px;
        padding: 16px 18px;
        background: #fcfcfd;
    }

    .denom-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(260px, 1fr));
        gap: 10px 28px;
    }

    .denom-line {
        display: flex;
        align-items: baseline;
        gap: 10px;
        font-variant-numeric: tabular-nums;
    }

    .denom-label {
        white-space: nowrap;
        font-weight: 600;
        color: #1f2937;
    }

    .denom-dots {
        flex: 1;
        border-bottom: 1px dotted #94a3b8;
        transform: translateY(-3px);
    }

    .denom-amount {
        min-width: 110px;
        text-align: right;
        font-weight: 700;
        color: #0f172a;
    }

    .denom-total {
        margin-top: 14px;
        padding-top: 12px;
        border-top: 1px solid #cbd5e1;
        display: flex;
        align-items: baseline;
        gap: 10px;
        font-variant-numeric: tabular-nums;
    }

        .denom-total .label {
            font-weight: 800;
            text-transform: uppercase;
            color: #111827;
        }

        .denom-total .dots {
            flex: 1;
            border-bottom: 1px dotted #64748b;
            transform: translateY(-3px);
        }

        .denom-total .amount {
            min-width: 140px;
            text-align: right;
            font-weight: 800;
            color: #111827;
        }

    .disbursement-box,
    .summary-box {
        border: 1px solid #dbe2ea;
        border-radius: 14px;
        padding: 18px 18px 16px;
        background: #fff;
    }

    .disbursement-group + .disbursement-group {
        margin-top: 20px;
    }

    .disbursement-group-title {
        font-size: 15px;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 10px;
    }

    .report-line {
        display: flex;
        align-items: baseline;
        gap: 10px;
        padding: 4px 0 4px 18px;
        font-variant-numeric: tabular-nums;
    }

    .report-line-main {
        color: #1f2937;
    }

        .report-line-main .voucher-no {
            color: #64748b;
            font-weight: 700;
            margin-right: 6px;
        }

        .report-line-main .payee {
            font-weight: 700;
        }

        .report-line-main .particular {
            color: #475569;
        }

    .report-line-dots {
        flex: 1;
        height: 1px;
        border-bottom: 1px dotted #94a3b8;
        margin: 0 6px;
    }

    .report-line-amount {
        min-width: 120px;
        text-align: right;
        font-weight: 700;
        color: #111827;
    }

    .group-total-line,
    .grand-total-line,
    .summary-line {
        display: flex;
        align-items: baseline;
        gap: 10px;
        font-variant-numeric: tabular-nums;
    }

    .group-total-line {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px 0 0 18px;
        width: 100%;
    }

    .line-label {
        width: 90px;
        flex: 0 0 90px;
    }

    .grand-total-line {
        margin-top: 18px;
        padding-top: 12px;
        border-top: 1px solid #cbd5e1;
    }

    .summary-line + .summary-line {
        margin-top: 10px;
    }

    .summary-line.strong,
    .grand-total-line {
        margin-top: 14px;
        padding-top: 12px;
        border-top: 1px solid #cbd5e1;
    }

    .line-label {
        font-weight: 700;
        color: #111827;
    }

    .line-dots {
        flex: 1 1 auto;
        width: 100%;
        border-bottom: 1px dotted #64748b;
        transform: translateY(-3px);
    }

    .line-amount {
        width: 140px;
        flex: 0 0 140px;
        text-align: right;
        font-weight: 800;
        color: #111827;
    }

    .muted-note {
        font-size: 12px;
        color: #64748b;
        margin-top: 8px;
    }

    @@media print {
        .report-topbar,
        .navbar,
        .sidebar,
        footer {
            display: none !important;
        }

        .report-page {
            max-width: none;
            padding: 0;
        }

        .report-shell {
            border: 0;
            box-shadow: none;
            border-radius: 0;
        }

        .report-content {
            padding: 0;
        }
    }

    @@media (max-width: 768px) {
        .report-content {
            padding: 22px 16px 28px;
        }

        .church-name {
            font-size: 22px;
        }

        .report-title {
            font-size: 16px;
        }

        .denom-grid {
            grid-template-columns: 1fr;
        }
    }

    .sub-report-title {
        font-size: 15px;
        font-weight: 800;
        color: #111827;
        text-transform: uppercase;
        margin-bottom: 12px;
    }

    .summary-spacer {
        margin-top: 26px;
    }

    .cash-disbursement-report {
        margin-bottom: 6px;
    }

    .cash-disbursement-head,
    .cash-row {
        display: grid;
        grid-template-columns: 1.9fr 110px 110px 90px 110px;
        gap: 12px;
        align-items: start;
    }

    .cash-disbursement-head {
        font-weight: 800;
        color: #111827;
        text-transform: uppercase;
        padding-bottom: 8px;
        border-bottom: 1px solid #cbd5e1;
        margin-bottom: 8px;
    }

    
    .cash-row {
        display: grid;
        grid-template-columns: 1.9fr 110px 110px 90px 110px;
        gap: 12px;
        align-items: start;
        font-variant-numeric: tabular-nums;
    }

    .cash-row.first-row {
        margin-top: 10px;
    }

    .particulars-cell {
        padding-left: 10px;
    }

    .particular-main {
        font-weight: 400;
        color: #111827;
        line-height: 1.5;
        padding-left: 18px;
    }

    .particular-sub {
        color: #111827;
        line-height: 1.5;
        padding-left: 48px;
    }

    .cash-total-row {
        display: grid;
        grid-template-columns: 1.9fr 110px 110px 90px 110px;
        gap: 12px;
        align-items: center;
        margin-top: 10px;
        padding-top: 6px;
        font-variant-numeric: tabular-nums;
    }

    .cash-total-label {
        font-weight: 800;
        color: #111827;
        padding-left: 18px;
        align-self: start;
    }

    .cash-total-amount {
        grid-column: 3;
        text-align: left;
        font-weight: 400;
        color: #111827;
        border-top: 1px solid #111827;
        padding-top: 3px;
        padding-left: 6px;
    }

    .cash-total-return {
        grid-column: 5;
        text-align: left;
        font-weight: 400;
        color: #111827;
        border-top: 1px solid #111827;
        padding-top: 3px;
        padding-left: 6px;
    }

    .adjusted-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        max-width: 560px;
        margin-top: 18px;
        padding-left: 18px;
        font-variant-numeric: tabular-nums;
    }

    .adjusted-label {
        font-size: 15px;
        color: #111827;
    }

    .adjusted-amount {
        font-size: 18px;
        font-weight: 800;
        color: #111827;
        min-width: 140px;
        text-align: right;
    }

    .text-center {
        text-align: center;
    }

    @@media (max-width: 900px) {
        .cash-disbursement-head, .cash-row, .cash-total-row

    {
        grid-template-columns: 1.6fr 90px 90px 80px 90px;
        gap: 8px;
        font-size: 13px;
    }

    .particular-sub {
        padding-left: 30px;
    }

    }

    .voucher-block {
        margin-top: 14px;
    }

    .cash-row-main {
        margin-bottom: 2px;
    }

    .cash-row-detail {
        padding: 2px 0;
    }

    .col-amount,
    .col-total,
    .col-voucher,
    .col-return {
        padding-top: 0;
    }

    .record-code {
        font-weight: 600;
        font-size: 13px;
        color: #475569;
        margin-left: 6px;
    }

    .summary-disbursement-report {
        margin-top: 6px;
    }

    .summary-disbursement-head,
    .summary-group-row,
    .summary-grand-total-row {
        display: grid;
        grid-template-columns: 1fr 110px 110px;
        gap: 10px;
        align-items: start;
        font-variant-numeric: tabular-nums;
    }

    .summary-disbursement-head {
        font-weight: 800;
        color: #111827;
        text-transform: uppercase;
        margin-bottom: 8px;
    }

    .summary-col-text {
        text-align: left;
    }

    .summary-col-amount,
    .summary-col-total {
        text-align: right;
    }

    .summary-group-block {
        margin-top: 10px;
    }

    .summary-group-title {
        font-weight: 400;
        color: #111827;
        margin-bottom: 2px;
    }

    .summary-group-row {
        padding: 2px 0;
    }

    .summary-label-cell {
        padding-left: 66px;
        color: #111827;
    }

    .summary-grand-total-row {
        margin-top: 12px;
        padding-top: 8px;
        border-top: 1px solid #111827;
    }

    .summary-total-label {
        font-weight: 800;
        color: #111827;
    }

    .summary-grand-total-amount {
        font-weight: 800;
        color: #111827;
    }

    .amount-underline {
        border-bottom: 1px solid #111827;
        padding-bottom: 2px;
    }
</style>

<div class="report-page">
    <div class="report-shell">
        <div class="report-topbar">
            <form method="get" class="report-filter-form">
                <div class="report-filter-group">
                    <label asp-for="ReportDate">Report Date</label>
                    <input asp-for="ReportDate" type="date" />
                </div>
                <button type="submit" class="btn-report-load">Load Report</button>
            </form>
        </div>

        <div class="report-content">
            @if (!string.IsNullOrWhiteSpace(Model.Message))
            {
                <div class="report-message">@Model.Message</div>
            }

            <div class="report-header">
                <div class="church-name">ADELINA CHRISTIAN CHURCH</div>
                <div class="report-title">
                    FINANCIAL REPORT (@Model.Report.ReportDate.ToString("MMMM dd, yyyy"))
                </div>
            </div>

            <section class="report-section">
                <div class="report-section-title">
                    GIVING TABLE
                    @if (!string.IsNullOrWhiteSpace(Model.Report.Giving.RecordCode))
                    {
                        <span class="record-code">– @Model.Report.Giving.RecordCode</span>
                    }
                </div>

                <div class="giving-table-wrap">
                    <table class="giving-table">
                        <thead>
                            <tr>
                                <th class="text-left">Name</th>
                                <th class="text-right">Tithes</th>
                                <th class="text-right">Offerings</th>
                                <th class="text-right">Solomon</th>
                                <th class="text-right">Noah</th>
                                <th class="text-right">Mission</th>
                                <th class="text-right">Others</th>
                                <th class="text-right">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Report.Giving.Rows != null && Model.Report.Giving.Rows.Any())
                            {
                                foreach (var row in Model.Report.Giving.Rows)
                                {
                                    <tr>
                                        <td class="text-left name-cell">
                                            @row.Name
                                        </td>
                                        <td class="text-right">@(row.Tithes == 0 ? "" : row.Tithes.ToString("N2"))</td>
                                        <td class="text-right">@(row.Offerings == 0 ? "" : row.Offerings.ToString("N2"))</td>
                                        <td class="text-right">@(row.Solomon == 0 ? "" : row.Solomon.ToString("N2"))</td>
                                        <td class="text-right">@(row.Noah == 0 ? "" : row.Noah.ToString("N2"))</td>
                                        <td class="text-right">@(row.Mission == 0 ? "" : row.Mission.ToString("N2"))</td>
                                        <td class="text-right">@(row.Others == 0 ? "" : row.Others.ToString("N2"))</td>
                                        <td class="text-right">@(row.Total == 0 ? "" : row.Total.ToString("N2"))</td>
                                    </tr>
                                }

                                <tr class="total-row">
                                    <td class="text-left">TOTAL</td>
                                    <td class="text-right">@Model.Report.Giving.TotalTithes.ToString("N2")</td>
                                    <td class="text-right">@Model.Report.Giving.TotalOfferings.ToString("N2")</td>
                                    <td class="text-right">@Model.Report.Giving.TotalSolomon.ToString("N2")</td>
                                    <td class="text-right">@Model.Report.Giving.TotalNoah.ToString("N2")</td>
                                    <td class="text-right">@Model.Report.Giving.TotalMission.ToString("N2")</td>
                                    <td class="text-right">@Model.Report.Giving.TotalOthers.ToString("N2")</td>
                                    <td class="text-right">@Model.Report.Giving.GrandTotal.ToString("N2")</td>
                                </tr>
                            }
                            else
                            {
                                <tr>
                                    <td colspan="8" class="text-left">No giving entries found.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>

            <section class="report-section">
                <div class="report-section-title">Giving Denom</div>

                <div class="denom-box">
                    @if (Model.Report.Denomination.Exists && Model.Report.Denomination.Lines.Any())
                    {
                        <div class="denom-grid">
                            @foreach (var line in Model.Report.Denomination.Lines)
                            {
                                <div class="denom-line">
                                    <span class="denom-label">@line.Label x @line.Quantity</span>
                                    <span class="denom-dots"></span>
                                    <span class="denom-amount">@line.LineTotal.ToString("N2")</span>
                                </div>
                            }
                        </div>

                        <div class="denom-total">
                            <span class="label">Total Denomination</span>
                            <span class="dots"></span>
                            <span class="amount">@Model.Report.Denomination.Total.ToString("N2")</span>
                        </div>
                    }
                    else
                    {
                        <div class="report-empty">No denomination summary found.</div>
                    }
                </div>
            </section>

            <section class="report-section">
                <div class="report-section-title">Disbursement</div>

                <div class="disbursement-box">
                    @if (Model.Report.Disbursement.Groups != null && Model.Report.Disbursement.Groups.Any())
                    {
                        <div class="sub-report-title">Cash Disbursements (@Model.Report.ReportDate.ToString("MM/dd/yyyy"))</div>

                        <div class="cash-disbursement-report">
                            <div class="cash-disbursement-head">
                                <div class="col-particulars">Particulars</div>
                                <div class="col-amount text-right">Amount</div>
                                <div class="col-total text-right">Total</div>
                                <div class="col-voucher text-center">Voucher #</div>
                                <div class="col-return text-right">Cash Return</div>
                            </div>

                            @foreach (var voucher in Model.Report.Disbursement.Vouchers)
                            {
                                var lines = voucher.Lines ?? new List<acc_finance.Models.Reports.DisbursementLineVm>();

                                if (lines.Any())
                                {
                                    <div class="voucher-block">
                                        @for (int i = 0; i < lines.Count; i++)
                                        {
                                            var line = lines[i];
                                            bool isLast = i == lines.Count - 1;
                                            bool isSingle = lines.Count == 1;
                                            bool isFirst = i == 0;

                                            if (isFirst)
                                            {
                                                <div class="cash-row cash-row-main">
                                                    <div class="col-particulars particulars-cell">
                                                        <div class="particular-main">@voucher.Ministry - @voucher.Payee</div>
                                                    </div>
                                                    <div class="col-amount"></div>
                                                    <div class="col-total"></div>
                                                    <div class="col-voucher"></div>
                                                    <div class="col-return"></div>
                                                </div>
                                            }

                                            <div class="cash-row cash-row-detail">
                                                <div class="col-particulars particulars-cell">
                                                    <div class="particular-sub">@line.Particular</div>
                                                </div>

                                                <div class="col-amount text-right">
                                                    @if (!isSingle)
                                                    {
                                                        @line.AmountReleased.ToString("N2")
                                                    }
                                                </div>

                                                <div class="col-total text-right">
                                                    @if (isSingle)
                                                    {
                                                        @voucher.VoucherTotalReleased.ToString("N2")
                                                    }
                                                    else if (isLast)
                                                    {
                                                        @voucher.VoucherTotalReleased.ToString("N2")
                                                    }
                                                </div>

                                                <div class="col-voucher text-center">
                                                    @if (isSingle || isLast)
                                                    {
                                                        @voucher.VoucherNumber
                                                    }
                                                </div>

                                                <div class="col-return text-right">
                                                    @if (line.CashReturned > 0)
                                                    {
                                                        @line.CashReturned.ToString("N2")
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                            }
                            <div class="cash-total-row">
                                <div class="cash-total-label">TOTAL</div>
                                <div class="cash-total-amount">@Model.Report.Disbursement.TotalReleased.ToString("N2")</div>
                                <div class="cash-total-return">@Model.Report.Disbursement.TotalReturned.ToString("N2")</div>
                            </div>

                            <div class="adjusted-row">
                                <div class="adjusted-label">Adjusted disbursement</div>
                                <div class="adjusted-amount">@Model.Report.Disbursement.TotalNetDisbursement.ToString("N2")</div>
                            </div>
                        </div>

                        <div class="sub-report-title summary-spacer">Summary Disbursement</div>

                        <div class="summary-disbursement-report">
                            <div class="summary-disbursement-head">
                                <div class="summary-col-text">Summary</div>
                                <div class="summary-col-amount text-right">Amount</div>
                                <div class="summary-col-total text-right">Total</div>
                            </div>

                            @foreach (var group in Model.Report.Disbursement.Groups)
                            {
                                var lines = group.Lines ?? new List<acc_finance.Models.Reports.DisbursementLineVm>();
                                bool isSingle = lines.Count == 1;

                                <div class="summary-group-block">
                                    <div class="summary-group-title">@group.Ministry</div>

                                    @for (int i = 0; i < lines.Count; i++)
                                    {
                                        var line = lines[i];
                                        bool isLast = i == lines.Count - 1;

                                        <div class="summary-group-row">
                                            <div class="summary-col-text summary-label-cell">
                                                @line.SummaryLabel
                                            </div>

                                            <div class="summary-col-amount text-right @(isLast && !isSingle ? "amount-underline" : "")">
                                                @if (!isSingle)
                                                {
                                                    @line.NetAmount.ToString("N2")
                                                }
                                            </div>

                                            <div class="summary-col-total text-right">
                                                @if (isSingle || isLast)
                                                {
                                                    @group.GroupTotal.ToString("N2")
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            <div class="summary-grand-total-row">
                                <div class="summary-col-text summary-total-label">TOTAL</div>
                                <div class="summary-col-amount"></div>
                                <div class="summary-col-total text-right summary-grand-total-amount">
                                    @Model.Report.Disbursement.TotalNetDisbursement.ToString("N2")
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="report-empty">No disbursement report found.</div>
                    }
                </div>
            </section>

            <section class="report-section">
                <div class="report-section-title">Summary</div>

                <div class="summary-box">
                    <div class="summary-line">
                        <div class="line-label">Cash Receipts / Blessings</div>
                        <div class="line-dots"></div>
                        <div class="line-amount">@Model.Report.Summary.CashReceiptsOrBlessings.ToString("N2")</div>
                    </div>

                    <div class="summary-line">
                        <div class="line-label">Less: Cash Disbursement</div>
                        <div class="line-dots"></div>
                        <div class="line-amount">@Model.Report.Summary.LessCashDisbursements.ToString("N2")</div>
                    </div>

                    <div class="summary-line strong">
                        <div class="line-label">Net Cash Balance @Model.Report.ReportDate.ToString("MM/dd/yyyy")</div>
                        <div class="line-dots"></div>
                        <div class="line-amount">@Model.Report.Summary.NetCashBalance.ToString("N2")</div>
                    </div>
                </div>
            </section>
        </div>
    </div>
</div>