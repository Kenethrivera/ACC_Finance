@page
@{
    ViewData["Title"] = "Access Denied";
}

<div class="container text-center mt-5">
    <div class="alert alert-danger shadow-sm d-inline-block p-5 rounded">
        <h1 class="display-1 text-danger"><i class="bi bi-shield-lock-fill"></i></h1>
        <h2 class="fw-bold mt-3">Access Denied</h2>
        <p class="text-muted fs-5">You do not have the required permissions to view or perform an action to this page.</p>
        <a href="/" class="btn btn-primary mt-3">Return to Dashboard</a>
    </div>
</div>