<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"] - Finance</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
          integrity="sha384-XGjxtQfXaH2tnPFa9x+ruJTuLE3Aa6LhHSWRr1XeTyhezb4abCG4ccI5AkVDxqC+"
          crossorigin="anonymous">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    
    <style>
        body {
            background-color: #f8f9fa;
            font-family: 'Segoe UI', sans-serif;
        }

            body.sidebar-open {
                overflow: hidden;
            }

        :root {
            --brand-blue: #0d6efd;
        }

        .bg-primary {
            background-color: var(--brand-blue) !important;
        }

        .text-primary {
            color: var(--brand-blue) !important;
        }

        /* --- SIDEBAR STYLES --- */
        .sidebar {
            width: 260px;
            background: #212529;
            height: 100vh;
            position: fixed;
            top: 0;
            left: 0;
            z-index: 1050;
            transition: transform 0.3s ease-in-out;
            overflow-y: auto; 
            -webkit-overflow-scrolling: touch; 
            scrollbar-width: thin;
        }

        .main-content {
            margin-left: 260px;
            transition: all 0.3s;
            width: calc(100% - 260px);
            min-height: 100vh;
        }

        /* Sidebar Links */
        .nav-link {
            color: rgba(255,255,255,0.75);
            padding: 10px 15px;
            margin-bottom: 5px;
            border-radius: 8px;
            transition: 0.2s;
        }

            .nav-link:hover {
                color: #fff;
                background: rgba(255,255,255,0.1);
                transform: translateX(5px);
            }

            .nav-link.active {
                background: var(--brand-blue);
                color: white;
                box-shadow: 0 4px 10px rgba(13,110,253,0.4);
                font-weight: 600;
            }

            .nav-link i {
                margin-right: 10px;
                font-size: 1.1rem;
            }

        /* --- MOBILE ADJUSTMENTS --- */
        @@media (max-width: 768px) {
            .sidebar {
                transform: translateX(-100%); 
                width: 280px;
                box-shadow: none;
            }

                .sidebar.active {
                    transform: translateX(0);
                    box-shadow: 5px 0 15px rgba(0,0,0,0.5);
                }

            .main-content {
                margin-left: 0;
                width: 100%;
                padding-top: 70px !important; 
            }

            /* Overlay for mobile */
            .sidebar-overlay {
                display: none;
                position: fixed;
                top: 0;
                left: 0;
                width: 100vw;
                height: 100vh;
                background: rgba(0,0,0,0.5);
                z-index: 1040;
                backdrop-filter: blur(2px);
            }

                .sidebar-overlay.active {
                    display: block;
                }
        }

    </style>


</head>
<body>
    <nav class="navbar navbar-dark bg-primary d-md-none fixed-top shadow px-3" style="height: 60px;">
        <div class="d-flex align-items-center w-100">
            <button class="btn btn-link text-white p-0 me-3 border-0" id="sidebarToggle">
                <i class="bi bi-list fs-1"></i>
            </button>
            <a class="navbar-brand fw-bold d-flex align-items-center me-0" href="#">
                <img src="/images/acc_logo.jpg" width="35" height="35" class="rounded-circle me-2 border border-white">
                <span>ACC Finance</span>
            </a>
        </div>
    </nav>

    <div class="sidebar-overlay" id="overlay"></div>

    <div class="d-flex">
        <div class="sidebar d-flex flex-column p-3 text-white" id="sidebar">
            <div class="d-flex align-items-center justify-content-between mb-4 mt-2 px-2">
                <a href="/" class="d-flex align-items-center text-white text-decoration-none">
                    <img src="~/images/acc_logo.jpg" class="rounded-circle me-3 border border-2 border-white" width="45" height="45">
                    <div>
                        <div class="fw-bold fs-5">Finance</div>
                        <small class="text-white-50" style="font-size: 0.75rem;">Adelina Christian Church</small>
                    </div>
                </a>
                <button class="btn btn-sm btn-outline-secondary d-md-none text-white-50 border-0" id="sidebarClose">
                    <i class="bi bi-x-lg fs-5"></i>
                </button>
            </div>

            <hr class="text-white-50 my-2">

            <ul class="nav nav-pills flex-column mb-auto">
                <li class="nav-item">
                    <a asp-page="/Index" class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Index" ? "active" : "")">
                        <i class="bi bi-grid-1x2-fill"></i> Dashboard
                    </a>
                </li>

                <li class="nav-item">
                    <a asp-page="/Giving/Entry" class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Giving/Entry" ? "active" : "")">
                        <i class="bi bi-file-earmark-bar-graph-fill"></i> Sources of Blessings
                    </a>
                </li>

                <li class="nav-item">
                    <a asp-page="/Disbursements/Create" class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Disbursements/Create" ? "active" : "")">
                        <i class="bi bi-file-earmark-bar-graph-fill"></i> Disbursements
                    </a>
                </li>

                <li class="nav-item">
                    <a asp-page="/Reports/Monthly" class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Reports/Monthly" ? "active" : "")">
                        <i class="bi bi-file-earmark-bar-graph-fill"></i> Monthly Reports
                    </a>
                </li>

                <li class="nav-item">
                    <a asp-page="/Reports/Weekly" class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Reports/Weekly" ? "active" : "")">
                        <i class="bi bi-file-earmark-bar-graph-fill"></i> Weekly Reports
                    </a>
                </li>
            </ul>

            <hr class="text-white-50">

            <div class="dropdown">
                <a href="#" class="d-flex align-items-center text-white text-decoration-none dropdown-toggle p-2 rounded hover-bg-dark" id="dropdownUser1" data-bs-toggle="dropdown" aria-expanded="false">
                    <div class="bg-primary rounded-circle d-flex align-items-center justify-content-center me-2 shadow-sm" style="width:38px; height:38px; font-weight:bold;">
                        @User.FindFirst("FullName")?.Value.Substring(0, 1).ToUpper()
                    </div>
                    <div class="lh-1 me-2">
                        <div class="fw-bold small">@User.FindFirst("FullName")?.Value</div>
                        <small class="text-white-50" style="font-size: 0.7rem;">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</small>
                    </div>
                </a>
                <ul class="dropdown-menu dropdown-menu-dark shadow-lg border-0" aria-labelledby="dropdownUser1">
                    <li><a class="dropdown-item" asp-page="/Profile/Index">My Profile</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item text-danger" asp-page="/Logout"><i class="bi bi-box-arrow-right me-2"></i> Logout</a></li>
                </ul>
            </div>

            <div class="d-md-none" style="height: 50px;"></div>
        </div>

        <div class="main-content bg-light">
            <div class="container-fluid p-3 p-md-4 pt-md-4">
                <main role="main">
                    @RenderBody()
                </main>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        $(document).ready(function () {
            function toggleSidebar() {
                $('#sidebar').toggleClass('active');
                $('#overlay').toggleClass('active');
                $('body').toggleClass('sidebar-open');
            }

            // Click Handler for Hamburger
            $('#sidebarToggle').on('click', function (e) {
                e.stopPropagation();
                toggleSidebar();
            });

            // Click Handler for Overlay (Close)
            $('#overlay').on('click', function () {
                toggleSidebar();
            });

            // Click Handler for Close Button (Sidebar)
            $('#sidebarClose').on('click', function () {
                toggleSidebar();
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
   
</body>
</html>
