@page
@model acc_finance.Pages.Auth.ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot Password";
    Layout = null; // No sidebar for this page
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Security Recovery - ACC Finance</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        body {
            background-color: #f3f4f6;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .fade-in {
            animation: smoothFade 0.3s ease-out forwards;
        }

        @@keyframes smoothFade {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>
<body>

    <div class="container fade-in" style="max-width: 500px;">
        <div class="text-center mb-4">
            <img src="~/images/acc_logo.jpg" class="rounded-circle shadow-sm mb-3" width="70" height="70">
            <h3 class="fw-bold text-dark">Security Recovery</h3>
            <p class="text-muted">ACC Finance Internal Verification</p>
        </div>

        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4 p-md-5">

                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger rounded-3 small fw-bold">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i> @Model.ErrorMessage
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.SuccessMessage))
                {
                    <div class="alert alert-success rounded-3 small fw-bold">
                        <i class="bi bi-check-circle-fill me-2"></i> @Model.SuccessMessage
                    </div>
                }

                <!-- STEP 1: ENTER USERNAME -->
                @if (Model.CurrentStep == 1)
                {
                    <form method="post" asp-page-handler="VerifyUsername">
                        <div class="mb-4">
                            <label class="form-label text-muted small fw-bold text-uppercase">Account Username</label>
                            <input type="text" asp-for="UsernameInput" class="form-control form-control-lg rounded-3 bg-light" placeholder="Enter your username" required autofocus>
                        </div>
                        <button type="submit" class="btn btn-primary btn-lg rounded-pill w-100 fw-bold shadow-sm">Continue</button>
                        <div class="text-center mt-4">
                            <a href="/Login" class="text-decoration-none text-muted small"><i class="bi bi-arrow-left me-1"></i> Back to Login</a>
                        </div>
                    </form>
                }

                <!-- STEP 2: SECURITY QUESTION -->
                @if (Model.CurrentStep == 2)
                {
                    <div class="text-center mb-4">
                        <span class="badge bg-warning text-dark px-3 py-2 rounded-pill mb-2">
                            <i class="bi bi-shield-lock-fill me-1"></i> Identity Verification
                        </span>
                        <h5 class="fw-bold text-dark mt-2">@Model.CurrentQuestion.Question</h5>

                        @if (Model.CurrentQuestion.ShowPuzzle && !string.IsNullOrEmpty(Model.CurrentQuestion.PuzzleHint))
                        {
                            <div class="bg-light border rounded-3 p-3 mt-3 font-monospace fs-5 tracking-widest text-primary fw-bold" style="letter-spacing: 0.1em;">
                                @Model.CurrentQuestion.PuzzleHint
                            </div>
                        }
                    </div>

                    <form method="post" asp-page-handler="SubmitAnswer">
                        <div class="mb-4">
                            <input type="text" asp-for="AnswerInput" class="form-control form-control-lg rounded-3 border-primary" placeholder="Type your answer here..." required autocomplete="off" autofocus>
                            <div class="form-text mt-2 text-danger fw-bold"><i class="bi bi-shield-exclamation me-1"></i> Attempts remaining: @Model.AttemptsLeft</div>
                        </div>

                        <div class="d-flex gap-2">
                            @if (Model.CanSkip)
                            {
                                <button type="submit" asp-page-handler="SkipQuestion" class="btn btn-outline-secondary rounded-pill w-50 fw-bold" formnovalidate>
                                    <i class="bi bi-shuffle me-1"></i> Switch Question
                                </button>
                            }
                            else
                            {
                                <button type="button" class="btn btn-outline-secondary rounded-pill w-50 fw-bold disabled">
                                    <i class="bi bi-slash-circle me-1"></i> No Skips Left
                                </button>
                            }
                            <button type="submit" class="btn btn-primary rounded-pill w-50 fw-bold shadow-sm">Submit Answer</button>
                        </div>
                    </form>
                }

                <!-- STEP 3: RESET PASSWORD -->
                @if (Model.CurrentStep == 3)
                {
                    <div class="text-center mb-4">
                        <div class="bg-success text-white rounded-circle d-inline-flex justify-content-center align-items-center mb-3" style="width: 50px; height: 50px; font-size: 1.5rem;">
                            <i class="bi bi-check-lg"></i>
                        </div>
                        <h5 class="fw-bold text-dark">Create New Password</h5>
                        <p class="text-muted small">Your identity has been verified.</p>
                    </div>

                    <form method="post" asp-page-handler="ResetPassword">
                        <div class="mb-3 text-start">
                            <label class="form-label text-muted small fw-bold text-uppercase">New Password</label>
                            <input type="password" id="newPass" asp-for="ResetInput.NewPassword" class="form-control form-control-lg rounded-3" placeholder="Min. 8 characters" required>
                        </div>
                        <div class="mb-4 text-start">
                            <label class="form-label text-muted small fw-bold text-uppercase">Confirm Password</label>
                            <input type="password" id="confPass" asp-for="ResetInput.ConfirmPassword" class="form-control form-control-lg rounded-3" placeholder="Re-type new password" required>
                        </div>

                        <!-- 🚨 LIVE VALIDATION CHECKLIST 🚨 -->
                        <div class="mb-4 bg-light p-3 rounded-3 border border-secondary border-opacity-25 text-start">
                            <div class="small fw-bold mb-2 text-muted text-uppercase" style="letter-spacing: 0.05em;">Password Requirements:</div>
                            <div id="req-length" class="req-item text-danger small mb-1" style="transition: color 0.2s;">
                                <i class="bi bi-x-circle-fill me-1"></i> At least 8 characters
                            </div>
                            <div id="req-match" class="req-item text-danger small" style="transition: color 0.2s;">
                                <i class="bi bi-x-circle-fill me-1"></i> Passwords must match
                            </div>
                        </div>

                        <button type="submit" id="btnReset" class="btn btn-success btn-lg rounded-pill w-100 fw-bold shadow-sm" disabled>Save New Password</button>
                    </form>

                    <!-- Live validation script for step 3 -->
                    <script>
                        document.addEventListener('DOMContentLoaded', function() {
                            const p1 = document.getElementById('newPass');
                            const p2 = document.getElementById('confPass');
                            const btn = document.getElementById('btnReset');
                            const reqLength = document.getElementById('req-length');
                            const reqMatch = document.getElementById('req-match');

                            function check() {
                                let isValid = true;
                                const v1 = p1.value;
                                const v2 = p2.value;

                                // Check Length
                                if (v1.length >= 8) {
                                    reqLength.classList.replace("text-danger", "text-success");
                                    reqLength.innerHTML = '<i class="bi bi-check-circle-fill me-1"></i> At least 8 characters';
                                } else {
                                    reqLength.classList.replace("text-success", "text-danger");
                                    reqLength.innerHTML = '<i class="bi bi-x-circle-fill me-1"></i> At least 8 characters';
                                    isValid = false;
                                }

                                // Check Match
                                if (v1.length > 0 && v1 === v2) {
                                    reqMatch.classList.replace("text-danger", "text-success");
                                    reqMatch.innerHTML = '<i class="bi bi-check-circle-fill me-1"></i> Passwords match';
                                } else {
                                    reqMatch.classList.replace("text-success", "text-danger");
                                    reqMatch.innerHTML = '<i class="bi bi-x-circle-fill me-1"></i> Passwords match';
                                    isValid = false;
                                }

                                btn.disabled = !isValid;
                            }

                            p1.addEventListener('input', check);
                            p2.addEventListener('input', check);
                        });
                    </script>
                }
            </div>
        </div>
    </div>

</body>
</html>