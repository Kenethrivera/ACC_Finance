        function fillEntryForm(data, displayName) {
            const rowKey = document.getElementById("Input_RowKey");
            const memberId = document.getElementById("Input_MemberId");
            const selectedName = document.getElementById("selectedMemberName");
            const customName = document.getElementById("customNameInput");
            const tithes = document.getElementById("Input_Tithes");
            const offerings = document.getElementById("Input_Offerings");
            const solomon = document.getElementById("Input_Solomon");
            const noah = document.getElementById("Input_Noah");
            const mission = document.getElementById("Input_Mission");
            const others = document.getElementById("Input_Others");

            if (rowKey) rowKey.value = data.rowKey || "";
            if (memberId) memberId.value = data.memberId ?? "";
            if (selectedName) selectedName.value = displayName || data.displayName || data.customName || "";
            if (customName) customName.value = data.customName || "";
            if (tithes) tithes.value = data.tithes ?? 0;
            if (offerings) offerings.value = data.offerings ?? 0;
            if (solomon) solomon.value = data.solomon ?? 0;
            if (noah) noah.value = data.noah ?? 0;
            if (mission) mission.value = data.mission ?? 0;
            if (others) others.value = data.others ?? 0;

