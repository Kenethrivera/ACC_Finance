        function setEntrySectionEnabled(enabled) {
            document.getElementById("membersPanelBody")?.classList.toggle("disabled-panel", !enabled);
            document.getElementById("entryFormShell")?.classList.toggle("disabled-panel", !enabled);
            document.getElementById("membersEmptyNote")?.classList.toggle("hidden-soft", enabled);
