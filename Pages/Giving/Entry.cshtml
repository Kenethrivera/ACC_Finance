        function applyClosedState(isClosed) {
            const workPanels = document.getElementById("workPanels");
            const finalizeBtn = document.getElementById("finalizeBtn");
            const finalizedNote = document.getElementById("finalizedNote");
            const editHeader = document.getElementById("editColumnHeader");
            const tfootEditSpacer = document.getElementById("tfootEditSpacer");

            if (workPanels) workPanels.classList.toggle("d-none", isClosed);
            if (finalizeBtn) finalizeBtn.classList.toggle("d-none", isClosed || !document.getElementById("RecordId")?.value || document.getElementById("RecordId")?.value === "0");
            if (finalizedNote) finalizedNote.classList.toggle("d-none", !isClosed);
            if (editHeader) editHeader.style.display = isClosed ? "none" : "";
            if (tfootEditSpacer) tfootEditSpacer.style.display = isClosed ? "none" : "";

            document.querySelectorAll(".summary-edit-cell").forEach(cell => {
                cell.style.display = isClosed ? "none" : "";
