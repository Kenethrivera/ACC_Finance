        function renderSummaryRows(rows, isClosed) {
            const tbody = document.getElementById("summaryTableBody");
            tbody.innerHTML = "";
            const colSpan = isClosed ? 8 : 9;

            if (!rows || rows.length === 0) {
                tbody.innerHTML = `<tr id="noEntriesRow"><td colspan="${colSpan}" class="text-center text-muted py-4">No entries yet.</td></tr>`;
                return;
            }

            rows.forEach(row => {
                const rowClass = getRowClassByName(row.memberName);
                const editButton = isClosed ? "" : `<td class="text-center summary-edit-cell">
                            <button type="button" class="btn btn-outline-primary summary-edit-btn summary-edit-btn-js"
                                    data-row-key="${escapeHtml(row.rowKey || "")}" data-member-id="${row.memberId ?? ""}"
                                    data-member-name="${escapeHtml(row.memberName)}">Edit</button></td>`;

                tbody.insertAdjacentHTML("beforeend", `
                    <tr>
                        <td class="name-cell ${rowClass}">${escapeHtml(row.memberName)}</td>
                        <td class="text-end">${formatMoney(row.tithes)}</td>
                        <td class="text-end">${formatMoney(row.offerings)}</td>
                        <td class="text-end">${formatMoney(row.solomon)}</td>
                        <td class="text-end">${formatMoney(row.noah)}</td>
                        <td class="text-end">${formatMoney(row.mission)}</td>
                            <td class="text-end">${formatMoney(row.others)}</td>
                            <td class="text-end fw-bold">${formatMoneyTotal(row.total)}</td>
                        ${editButton}
                    </tr>
                `);
            });
        }

        async function loadMemberEntryByMember(memberId, memberName) {
            const recordId = document.getElementById("RecordId")?.value;
            if (!recordId || recordId === "0") {
                showToast("Error", "Create or load a record first.", false);
                return;
            }

            try {
                const response = await fetch(`?handler=MemberEntry&recordId=${recordId}&memberId=${memberId}`);
                const data = await response.json();

                if (!data.success) {
                    showToast("Error", data.message || "Unable to load entry.", false);
                    return;
                }

                fillEntryForm(data, memberName);
                selectMemberVisual(memberId, data.rowKey || "");
                document.getElementById("member-entry-section")?.scrollIntoView({ behavior: "smooth", block: "start" });
            } catch {
                showToast("Error", "Failed to load member entry.", false);
            }
        }

        async function loadEntryByRow(rowKey, memberName) {
            const recordId = document.getElementById("RecordId")?.value;
            if (!recordId || recordId === "0" || !rowKey) return;

            try {
                const response = await fetch(`?handler=EntryRow&recordId=${recordId}&rowKey=${encodeURIComponent(rowKey)}`);
                const data = await response.json();

                if (!data.success) {
                    showToast("Error", data.message || "Unable to load row.", false);
                    return;
                }

                fillEntryForm(data, memberName);
                selectMemberVisual(data.memberId, rowKey);
                document.getElementById("member-entry-section")?.scrollIntoView({ behavior: "smooth", block: "start" });
            } catch {
                showToast("Error", "Failed to load selected row.", false);
            }
