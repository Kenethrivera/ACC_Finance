        function resetEntryForm() {
            fillEntryForm({
                rowKey: "", memberId: "", customName: "",
                tithes: 0, offerings: 0, solomon: 0, noah: 0, mission: 0, others: 0
            }, "");

            document.querySelectorAll(".member-btn").forEach(btn => {
                btn.classList.remove("active-member");
