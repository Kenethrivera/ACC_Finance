@page
@model acc_finance.Pages.Giving.EntryModel
@{
    ViewData["Title"] = "Giving Entry";
    var hasRecord = Model.RecordId > 0;
}

@functions {
    public string GetNameChipClass(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "chip-person";

        var lower = name.ToLower();

        if (lower.Contains("kids") || lower.Contains("prayer") || lower.Contains("youth") ||
            lower.Contains("camp") || lower.Contains("meeting") || lower.Contains("group"))
            return "chip-group";

        if (name.Contains("&"))
            return "chip-family";

        return "chip-person";
    }
}

<style>
    .giving-page {
        font-size: 0.95rem;
    }

    .card-soft {
        border: 1px solid #d9dce7;
        border-radius: 14px;
        box-shadow: 0 4px 14px rgba(24, 39, 75, .06);
    }

    .section-title {
        font-size: 1rem;
        font-weight: 700;
        color: #24324b;
        margin-bottom: 0;
    }

    .member-panel-scroll {
        max-height: 560px;
        overflow-y: auto;
        padding-right: 4px;
    }

    .member-btn {
        min-height: 60px;
        white-space: normal;
        text-align: left;
        font-weight: 600;
        border-radius: 12px;
        color: #23314d !important;
        border-width: 1px;
        opacity: 1 !important;
    }

    .chip-person {
        background: #ffffff;
        border-color: #cfd6e4;
    }

    .chip-family {
        background: #fff4d6;
        border-color: #f0c36d;
    }

    .chip-group {
        background: #e8f3ff;
        border-color: #7fb2ff;
    }

    .member-btn.active-member {
        background: #3658d7 !important;
        color: #fff !important;
        border-color: #3658d7 !important;
    }

    .mini-note {
        font-size: .85rem;
        color: #667085;
    }

    .excel-wrap {
        border: 1px solid #aeb6d0;
        border-radius: 0;
        overflow: hidden;
    }

    .excel-table {
        margin-bottom: 0;
        font-size: .93rem;
    }

        .excel-table thead th {
            background: #5a64b8;
            color: #fff;
            border-color: #7079c7;
            font-weight: 700;
            text-transform: uppercase;
            font-size: .84rem;
            letter-spacing: .02em;
            padding: .45rem .55rem;
        }

        .excel-table tbody td {
            background: #f7f8fc;
            border-color: #e2e6f0;
            padding: .32rem .5rem;
            color: #24324b;
        }

        .excel-table tbody tr:nth-child(even) td {
            background: #eef1f8;
        }

        .excel-table tfoot td {
            background: #ffffff;
            border-top: 2px solid #444;
            font-weight: 800;
            color: #1d2433;
            padding: .4rem .5rem;
        }

    .name-cell {
        font-weight: 600;
        color: #22304c !important;
    }

    .name-family {
        background: #fff7df !important;
    }

    .name-group {
        background: #eaf4ff !important;
    }

    .summary-edit-btn {
        padding: .18rem .45rem;
        font-size: .78rem;
    }

    .toast-container {
        z-index: 1085;
    }

    .floating-toast {
        min-width: 300px;
    }

    .toolbar-badge {
        font-size: .8rem;
        padding: .45rem .7rem;
        border-radius: 999px;
    }

    .custom-entry-box {
        border: 1px dashed #c8d0e0;
        background: #fafbff;
        border-radius: 12px;
        padding: 12px;
    }

    .server-banner {
        border-radius: 12px;
    }

    .action-banner-wrap {
        position: sticky;
        top: 12px;
        z-index: 1060;
    }

    .action-banner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        overflow: hidden;
        opacity: 0;
        max-height: 0;
        margin-bottom: 0;
        padding: 0 16px;
        border-width: 0;
        box-shadow: none;
        pointer-events: none;
        transition: opacity 0.25s ease, max-height 0.25s ease, margin-bottom 0.25s ease, padding-top 0.25s ease, padding-bottom 0.25s ease, border-width 0.25s ease, box-shadow 0.25s ease;
    }

        .action-banner.show {
            opacity: 1;
            max-height: 120px;
            margin-bottom: 14px;
            padding: 14px 16px;
            border-width: 1px;
            box-shadow: 0 8px 24px rgba(24, 39, 75, .10);
            pointer-events: auto;
        }

    .action-banner-left {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .action-banner-title {
        font-weight: 700;
        margin-bottom: 2px;
    }

    .action-banner-message {
        font-size: .92rem;
        color: #475467;
    }

    .action-banner.loading {
        background: #eef4ff;
        border-color: #bfd3ff;
    }

    .action-banner.success {
        background: #ecfdf3;
        border-color: #a6f4c5;
    }

    .action-banner.error {
        background: #fef3f2;
        border-color: #fecdca;
    }

    .spinner-inline {
        width: 1.2rem;
        height: 1.2rem;
        flex: 0 0 auto;
    }

    .btn-finalizing {
        pointer-events: none;
        opacity: .7;
    }

    .disabled-panel {
        opacity: .65;
        pointer-events: none;
    }

    .empty-panel-note {
        color: #667085;
        font-size: .9rem;
        padding: 10px 0 0 0;
    }

    .hidden-soft {
        display: none !important;
    }

    .denom-section-compact {
        border: 1px solid #d9dce7;
        border-radius: 22px;
        padding: 16px 18px;
        background: #fbfcff;
    }

    .denom-compact-wrap {
        display: grid;
        grid-template-columns: minmax(0, 1.9fr) minmax(220px, 280px);
        gap: 18px;
        align-items: stretch;
    }

    .denom-compact-grid {
        display: grid;
        grid-template-columns: repeat(5, minmax(70px, 1fr));
        gap: 10px 12px;
        align-content: start;
    }

    .denom-mini {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-start;
        gap: 6px;
    }

    .denom-mini-label {
        font-size: 0.85rem;
        font-weight: 700;
        color: #4b5875;
        text-align: center;
        line-height: 1.1;
        min-height: 30px;
        display: flex;
        align-items: flex-end; 
        justify-content: center;
        padding-bottom: 4px;
    }

    .denom-total-box.status-waiting {
        border-color: #cfd6e4;
        background: linear-gradient(180deg, #f8faff 0%, #ffffff 100%);
        box-shadow: 0 0 0 3px rgba(207, 214, 228, 0.15);
    }

    .denom-status.waiting {
        background: #f1f3f8;
        color: #4b5875;
    }

    .denom-mini-input {
        width: 78px;
        height: 44px;
        text-align: center;
        font-weight: 700;
        font-size: .95rem;
        border-radius: 10px;
        border: 1px solid #cfd6e4;
        background: #fff;
    }

    .denom-total-box {
        border: 2px solid #d9dce7;
        border-radius: 18px;
        padding: 16px;
        background: linear-gradient(180deg, #f8faff 0%, #ffffff 100%);
        display: flex;
        flex-direction: column;
        justify-content: center;
        min-height: 170px;
    }

        .denom-total-box.status-match {
            border-color: #a6f4c5;
            background: linear-gradient(180deg, #ecfdf3 0%, #f8fffb 100%);
            box-shadow: 0 0 0 3px rgba(18,183,106,.08);
        }

        .denom-total-box.status-missing {
            border-color: #fedf89;
            background: linear-gradient(180deg, #fffaeb 0%, #fffdf7 100%);
            box-shadow: 0 0 0 3px rgba(247,144,9,.07);
        }

        .denom-total-box.status-over {
            border-color: #fecdca;
            background: linear-gradient(180deg, #fef3f2 0%, #fff9f8 100%);
            box-shadow: 0 0 0 3px rgba(240,68,56,.07);
        }

    .denom-total-title {
        font-size: .78rem;
        text-transform: uppercase;
        letter-spacing: .06em;
        color: #667085;
        font-weight: 800;
        margin-bottom: 8px;
    }

    .denom-total-main {
        font-size: 1.8rem;
        font-weight: 800;
        color: #1f2a44;
        line-height: 1.05;
        margin-bottom: 10px;
    }

    .denom-total-helper {
        font-size: .88rem;
        color: #475467;
        margin-bottom: 12px;
    }

    .denom-total-lines {
        display: grid;
        gap: 6px;
        font-size: .9rem;
    }

    .denom-total-line {
        display: flex;
        justify-content: space-between;
        gap: 12px;
    }

        .denom-total-line strong {
            color: #1f2a44;
        }

    @@media (max-width: 991.98px) {
        .denom-compact-wrap {
            grid-template-columns: 1fr;
        }

        .denom-compact-grid {
            grid-template-columns: repeat(4, minmax(70px, 1fr));
        }
    }

    @@media (max-width: 575.98px) {
        .denom-compact-grid {
            grid-template-columns: repeat(2, minmax(70px, 1fr));
        }

        .denom-mini-input {
            width: 100%;
        }
    }

    .denom-summary-wrap {
        padding: 4px 2px 2px 2px;
    }

    .denom-summary-top {
        display: grid;
        grid-template-columns: 1.4fr 1fr;
        gap: 18px;
        margin-bottom: 18px;
    }

    .denom-summary-main {
        background: linear-gradient(135deg, #f8f9ff 0%, #eef2ff 100%);
        border: 1px solid #d9e1ff;
        border-radius: 18px;
        padding: 22px;
    }

    .denom-summary-label {
        font-size: .82rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .06em;
        color: #5f6b85;
        margin-bottom: 8px;
    }

    .denom-summary-total {
        font-size: 2.2rem;
        line-height: 1;
        font-weight: 800;
        color: #1d2b4f;
        margin-bottom: 10px;
    }

    .denom-summary-sub {
        color: #667085;
        font-size: .95rem;
    }

    .denom-summary-side {
        display: grid;
        gap: 12px;
    }

    .denom-metric-card {
        background: #fff;
        border: 1px solid #e3e7ef;
        border-radius: 16px;
        padding: 14px 16px;
    }

    .denom-metric-label {
        font-size: .8rem;
        font-weight: 700;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: .04em;
        margin-bottom: 6px;
    }

    .denom-metric-value {
        font-size: 1.15rem;
        font-weight: 800;
        color: #1f2937;
    }

        .denom-metric-value.ok {
            color: #1f7a45;
        }

        .denom-metric-value.bad {
            color: #b42318;
        }

    .denom-breakdown-title {
        font-size: .95rem;
        font-weight: 700;
        color: #24324b;
        margin: 8px 0 12px 0;
    }

    .denom-summary-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(110px, 1fr));
        gap: 12px;
    }

    .denom-summary-item {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        padding: 12px;
        text-align: center;
    }

    .denom-summary-item-label {
        font-size: .8rem;
        font-weight: 700;
        color: #64748b;
        margin-bottom: 6px;
    }

    .denom-summary-item-value {
        font-size: 1.1rem;
        font-weight: 800;
        color: #0f172a;
    }

    @@media (max-width: 768px) {
        .denom-summary-top
        {
            grid-template-columns: 1fr;
        }

        .denom-summary-total {
            font-size: 1.8rem;
        }
    }

    .denom-final-wrap {
        display: grid;
        grid-template-columns: minmax(0, 1.6fr) minmax(240px, 320px);
        gap: 20px;
        align-items: start;
    }

    .denom-final-left {
        padding: 4px 4px 4px 0;
    }

    .denom-final-label {
        font-size: .82rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .06em;
        color: #667085;
        margin-bottom: 12px;
    }

    .denom-final-list {
        display: grid;
        gap: 10px;
    }

    .denom-final-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        padding: 12px 14px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
    }

    .denom-final-row-left {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    .denom-final-bill {
        font-weight: 800;
        color: #1f2937;
        min-width: 70px;
    }

    .denom-final-times {
        color: #667085;
        font-weight: 600;
    }

    .denom-final-row-amount {
        font-weight: 800;
        color: #0f172a;
    }

    .denom-final-right {
        display: flex;
    }

    .denom-final-total-card {
        width: 100%;
        background: linear-gradient(135deg, #f8f9ff 0%, #eef6ff 100%);
        border: 1px solid #d9e6ff;
        border-radius: 18px;
        padding: 20px;
    }

    .denom-final-total-label {
        font-size: .82rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .06em;
        color: #5f6b85;
        margin-bottom: 8px;
    }

    .denom-final-total-value {
        font-size: 2.2rem;
        line-height: 1;
        font-weight: 800;
        color: #1d2b4f;
        margin-bottom: 16px;
    }

    .denom-final-total-meta {
        display: grid;
        gap: 10px;
    }

    .denom-final-total-line {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        font-size: .95rem;
        color: #344054;
    }

        .denom-final-total-line strong {
            font-weight: 800;
            color: #0f172a;
        }

            .denom-final-total-line strong.ok {
                color: #1f7a45;
            }

            .denom-final-total-line strong.bad {
                color: #b42318;
            }

    .denom-final-empty {
        padding: 14px;
        border: 1px dashed #d0d5dd;
        border-radius: 14px;
        color: #667085;
        background: #fcfcfd;
    }

    @@media (max-width: 768px) {
        .denom-final-wrap

    {
        grid-template-columns: 1fr;
    }

    .denom-final-total-value {
        font-size: 1.8rem;
    }

    }

       
</style>

<div class="container-fluid py-3 giving-page">
    <div class="action-banner-wrap">
        <div id="actionBanner" class="action-banner" role="alert" aria-live="polite">
            <div class="action-banner-left">
                <div id="actionBannerSpinner" class="spinner-border spinner-border-sm spinner-inline text-primary" role="status"></div>
                <div>
                    <div id="actionBannerTitle" class="action-banner-title">Processing</div>
                    <div id="actionBannerMessage" class="action-banner-message">Please wait...</div>
                </div>
            </div>
            <button type="button" id="actionBannerCloseBtn" class="btn-close"></button>
        </div>
    </div>

    <div class="row g-3">

        <div class="col-12">
            <div class="card card-soft">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                        <div>
                            <h3 class="mb-1 fw-bold">Giving Entry</h3>
                            <div class="mini-note">Load Existing Records can be done via Date Filter</div>
                        </div>

                        <span id="recordStatusBadge"
                              class="toolbar-badge @(Model.IsClosed ? "bg-secondary text-white" : "bg-info-subtle text-dark")">
                            @(Model.IsClosed ? "Finalized" : "Draft")
                        </span>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(Model.Message))
                    {
                        <div class="alert alert-warning alert-dismissible fade show server-banner mb-3" role="alert">
                            @Model.Message
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form id="recordHeaderForm" class="row g-3 align-items-end" onsubmit="return false;">
                        @Html.AntiForgeryToken()

                        <div class="col-md-3">
                            <label asp-for="Header.RecordCode" class="form-label fw-semibold">Record Code</label>
                            <input asp-for="Header.RecordCode" class="form-control" />
                        </div>

                        <div class="col-md-3">
                            <label asp-for="Header.ServiceDate" class="form-label fw-semibold">Date</label>
                            <input asp-for="Header.ServiceDate" type="date" class="form-control" />
                        </div>

                        <div class="col-md-3">
                            <button type="button" id="loadRecordBtn" class="btn btn-outline-primary w-100">
                                Load Existing
                            </button>
                        </div>

                        <div class="col-md-3">
                            <button type="button" id="createRecordBtn" class="btn btn-primary w-100">
                                Create New
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div id="workPanels" class="col-12 @(Model.IsClosed ? "d-none" : "")">
            <div class="row g-3">
                <div class="col-lg-7">
                    <div class="card card-soft h-100">
                        <div class="card-header bg-white border-0 pb-0">
                            <h5 class="section-title">Names / Members</h5>
                        </div>

                        <div class="card-body">
                            <div id="membersPanelBody" class="@(!hasRecord ? "disabled-panel" : "")">
                                <div class="custom-entry-box mb-3">
                                    <div class="row g-2 align-items-end">
                                        <div class="col-md-8">
                                            <label class="form-label fw-semibold">Add name not in list</label>
                                            <input id="customNameInput" class="form-control" placeholder="Example: Anonymous, Visitors" />
                                        </div>
                                        <div class="col-md-4">
                                            <button type="button" id="useCustomNameBtn" class="btn btn-outline-dark w-100">
                                                Use Custom Name
                                            </button>
                                        </div>
                                    </div>
                                    <div class="mini-note mt-2">
                                        Anonymous can be encoded multiple times as separate rows.
                                    </div>
                                </div>

                                <div class="member-panel-scroll">
                                    <div class="row g-2">
                                        @{
                                            var orderedMembers = Model.Members
                                            .OrderBy(m =>
                                            {
                                                var lower = m.Name.ToLower();

                                                bool isGroup = lower.Contains("kids")
                                                                            || lower.Contains("prayer")
                                                                            || lower.Contains("meeting")
                                                                            || lower.Contains("group")
                                                                            || lower.Contains("youth")
                                                                            || lower.Contains("camp");

                                                bool isFamily = m.Name.Contains("&");

                                                if (!isFamily && !isGroup) return 1;
                                                if (isFamily) return 2;
                                                return 3;
                                            })
                                            .ThenBy(m => m.Name)
                                            .ToList();
                                        }

                                        @foreach (var member in orderedMembers)
                                        {
                                            var isSelected = Model.SelectedMemberId == member.Id;

                                            <div class="col-md-4 col-sm-6">
                                                <button type="button"
                                                        class="btn member-btn w-100 @GetNameChipClass(member.Name) @(isSelected ? "active-member" : "")"
                                                        data-member-id="@member.Id"
                                                        data-member-name="@member.Name"
                                                        data-row-key="">
                                                    @member.Name
                                                </button>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>

                            <div id="membersEmptyNote" class="empty-panel-note @((hasRecord) ? "hidden-soft" : "")">
                                Create or load a record first.
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-5">
                    <div class="card card-soft h-100" id="member-entry-section">
                        <div class="card-header bg-white border-0 pb-0">
                            <h5 class="section-title">Selected Entry</h5>
                        </div>

                        <div class="card-body">
                            <form id="memberEntryForm" onsubmit="return false;">
                                @Html.AntiForgeryToken()

                                <input type="hidden" id="RecordId" value="@Model.RecordId" />
                                <input type="hidden" id="Input_RowKey" value="@(Model.Input.RowKey ?? "")" />
                                <input type="hidden" id="Input_MemberId" value="@(Model.Input.MemberId?.ToString() ?? "")" />

                                <div id="entryFormShell" class="@(!hasRecord ? "disabled-panel" : "")">
                                    <div class="mb-3">
                                        <label class="form-label fw-semibold">Selected Name</label>
                                        <input id="selectedMemberName" class="form-control" value="@Model.Input.DisplayName" readonly />
                                    </div>

                                    <div class="row g-3">
                                        <div class="col-md-4">
                                            <label class="form-label">Tithes</label>
                                            <input id="Input_Tithes" class="form-control money-input" type="number" step="0.01" min="0" value="@Model.Input.Tithes" />
                                        </div>

                                        <div class="col-md-4">
                                            <label class="form-label">Offerings</label>
                                            <input id="Input_Offerings" class="form-control money-input" type="number" step="0.01" min="0" value="@Model.Input.Offerings" />
                                        </div>

                                        <div class="col-md-4">
                                            <label class="form-label">Solomon</label>
                                            <input id="Input_Solomon" class="form-control money-input" type="number" step="0.01" min="0" value="@Model.Input.Solomon" />
                                        </div>

                                        <div class="col-md-4">
                                            <label class="form-label">Noah</label>
                                            <input id="Input_Noah" class="form-control money-input" type="number" step="0.01" min="0" value="@Model.Input.Noah" />
                                        </div>

                                        <div class="col-md-4">
                                            <label class="form-label">Mission</label>
                                            <input id="Input_Mission" class="form-control money-input" type="number" step="0.01" min="0" value="@Model.Input.Mission" />
                                        </div>

                                        <div class="col-md-4">
                                            <label class="form-label">Others</label>
                                            <input id="Input_Others" class="form-control money-input" type="number" step="0.01" min="0" value="@Model.Input.Others" />
                                        </div>
                                    </div>

                                    <div class="mt-3">
                                        <label class="form-label fw-semibold">Total</label>
                                        <input id="displayTotal" class="form-control" value="@Model.Input.DisplayTotal.ToString("0.00")" readonly />
                                    </div>

                                    <div class="mt-4">
                                        <button type="button" id="saveMemberBtn" class="btn btn-success w-100">
                                            Save Row
                                        </button>
                                    </div>
                                </div>

                                <div id="entryEmptyNote" class="empty-panel-note @((hasRecord) ? "hidden-soft" : "")">
                                    Create or load a record first.
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="card card-soft">
                <div class="card-header bg-white border-0">
                    <div id="summaryHeaderBar" class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <h5 class="section-title">
                            Sources of Blessings <span id="summaryDateLabel">@Model.Header.ServiceDate.ToString("MM/dd/yyyy")</span>
                        </h5>

                        <button type="button"
                                id="finalizeBtn"
                                class="btn btn-primary @((!hasRecord || Model.IsClosed) ? "d-none" : "")">
                            Finalize Record
                        </button>
                    </div>
                </div>

                <div class="card-body">
                    <div class="excel-wrap">
                        <div class="table-responsive">
                            <table class="table excel-table align-middle">
                                <thead>
                                    <tr>
                                        <th id="summaryTitleCell" style="min-width:260px;">Sources of Blessings @Model.Header.ServiceDate.ToString("MM/dd/yyyy")</th>
                                        <th class="text-end">Tithes</th>
                                        <th class="text-end">Offerings</th>
                                        <th class="text-end">Solomon</th>
                                        <th class="text-end">Noah</th>
                                        <th class="text-end">Mission</th>
                                        <th class="text-end">Others</th>
                                        <th class="text-end">Total</th>
                                        <th class="text-center" id="editColumnHeader" style="@(Model.IsClosed ? "display:none;" : "")">Edit</th>
                                    </tr>
                                </thead>

                                <tbody id="summaryTableBody">
                                    @if (Model.SummaryRows.Any())
                                    {
                                        @foreach (var row in Model.SummaryRows)
                                        {
                                            var rowClass = "";
                                            if (row.MemberName.Contains("&"))
                                            {
                                                rowClass = "name-family";
                                            }
                                            else
                                            {
                                                var lower = row.MemberName.ToLower();
                                                if (lower.Contains("kids") || lower.Contains("prayer") || lower.Contains("youth") ||
                                                lower.Contains("camp") || lower.Contains("meeting") || lower.Contains("group"))
                                                {
                                                    rowClass = "name-group";
                                                }
                                            }

                                            <tr>
                                                <td class="name-cell @rowClass">@row.MemberName</td>
                                                <td class="text-end">@(row.Tithes == 0 ? "" : row.Tithes.ToString("0.00"))</td>
                                                <td class="text-end">@(row.Offerings == 0 ? "" : row.Offerings.ToString("0.00"))</td>
                                                <td class="text-end">@(row.Solomon == 0 ? "" : row.Solomon.ToString("0.00"))</td>
                                                <td class="text-end">@(row.Noah == 0 ? "" : row.Noah.ToString("0.00"))</td>
                                                <td class="text-end">@(row.Mission == 0 ? "" : row.Mission.ToString("0.00"))</td>
                                                <td class="text-end">@(row.Others == 0 ? "" : row.Others.ToString("0.00"))</td>
                                                <td class="text-end fw-bold">@(row.Total == 0 ? "" : row.Total.ToString("#,##0.00"))</td>
                                                <td class="text-center summary-edit-cell" style="@(Model.IsClosed ? "display:none;" : "")">
                                                    <button type="button"
                                                            class="btn btn-outline-primary summary-edit-btn summary-edit-btn-js"
                                                            data-row-key="@row.RowKey"
                                                            data-member-id="@(row.MemberId?.ToString() ?? "")"
                                                            data-member-name="@row.MemberName">
                                                        Edit
                                                    </button>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr id="noEntriesRow">
                                            <td colspan="9" class="text-center text-muted py-4">No entries yet.</td>
                                        </tr>
                                    }
                                </tbody>

                                <tfoot>
                                    <tr>
                                        <td>TOTAL</td>
                                        <td class="text-end" id="totalTithes">@Model.TotalTithes.ToString("#,##0.00")</td>
                                        <td class="text-end" id="totalOfferings">@Model.TotalOfferings.ToString("#,##0.00")</td>
                                        <td class="text-end" id="totalSolomon">@Model.TotalSolomon.ToString("#,##0.00")</td>
                                        <td class="text-end" id="totalNoah">@Model.TotalNoah.ToString("#,##0.00")</td>
                                        <td class="text-end" id="totalMission">@Model.TotalMission.ToString("#,##0.00")</td>
                                        <td class="text-end" id="totalOthers">@Model.TotalOthers.ToString("#,##0.00")</td>
                                        <td class="text-end" id="grandTotal">@Model.GrandTotal.ToString("#,##0.00")</td>
                                        <td id="tfootEditSpacer" style="@(Model.IsClosed ? "display:none;" : "")"></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>

                    <div id="finalizedNote" class="mt-3 alert alert-secondary mb-0 @(Model.IsClosed ? "" : "d-none")">
                        This record is finalized. Only the summary table is shown.
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="card card-soft mb-3">
                <div class="card-header bg-white border-0">
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <h5 class="section-title mb-0">Denomination of Money</h5>

                        @if (Model.IsClosed)
                        {
                            <div class="denom-status match">Finalized</div>
                        }
                        else
                        {
                            <div id="denomStatusPill"
                                 class="denom-status @(Model.GrandTotal <= 0 ? "waiting" : (Model.IsDenominationMatched ? "match" : (Model.DenominationDifference < 0 ? "missing" : "over")))">
                                @(Model.GrandTotal <= 0 ? "Waiting" : (Model.IsDenominationMatched ? "Matched" : (Model.DenominationDifference < 0 ? "Missing" : "Over")))
                            </div>
                        }
                    </div>
                </div>

                <div class="card-body">

                    <div id="denomInputSection" class="@(Model.IsClosed ? "d-none" : "")">
                        <div class="denom-section-compact">
                            <div class="denom-compact-wrap">
                                <div>
                                    <div class="denom-compact-grid">
                                        <div class="denom-mini">
                                            <div class="denom-mini-label">1000</div>
                                            <input id="Denom_1000" class="form-control denom-input denom-mini-input" type="number" min="0" value="@Model.Denomination.Qty1000" />
                                        </div>

                                        <div class="denom-mini">
                                            <div class="denom-mini-label">500</div>
                                            <input id="Denom_500" class="form-control denom-input denom-mini-input" type="number" min="0" value="@Model.Denomination.Qty500" />
                                        </div>

                                        <div class="denom-mini">
                                            <div class="denom-mini-label">200</div>
                                            <input id="Denom_200" class="form-control denom-input denom-mini-input" type="number" min="0" value="@Model.Denomination.Qty200" />
                                        </div>

                                        <div class="denom-mini">
                                            <div class="denom-mini-label">100</div>
                                            <input id="Denom_100" class="form-control denom-input denom-mini-input" type="number" min="0" value="@Model.Denomination.Qty100" />
                                        </div>

                                        <div class="denom-mini">
                                            <div class="denom-mini-label">50</div>
                                            <input id="Denom_50" class="form-control denom-input denom-mini-input" type="number" min="0" value="@Model.Denomination.Qty50" />
                                        </div>

                                        <div class="denom-mini">
                                            <div class="denom-mini-label">20 Coins</div>
                                            <input id="Denom_20Coin" class="form-control denom-input denom-mini-input" type="number" min="0" value="@Model.Denomination.Qty20Coin" />
                                        </div>

                                        <div class="denom-mini">
                                            <div class="denom-mini-label">20 Paper</div>
                                            <input id="Denom_20Paper" class="form-control denom-input denom-mini-input" type="number" min="0" value="@Model.Denomination.Qty20Paper" />
                                        </div>

                                        <div class="denom-mini">
                                            <div class="denom-mini-label">10</div>
                                            <input id="Denom_10" class="form-control denom-input denom-mini-input" type="number" min="0" value="@Model.Denomination.Qty10" />
                                        </div>

                                        <div class="denom-mini">
                                            <div class="denom-mini-label">5</div>
                                            <input id="Denom_5" class="form-control denom-input denom-mini-input" type="number" min="0" value="@Model.Denomination.Qty5" />
                                        </div>

                                        <div class="denom-mini">
                                            <div class="denom-mini-label">1</div>
                                            <input id="Denom_1" class="form-control denom-input denom-mini-input" type="number" min="0" value="@Model.Denomination.Qty1" />
                                        </div>

                                        <div class="denom-mini">
                                            <div class="denom-mini-label">25c</div>
                                            <input id="Denom_25Cent" class="form-control denom-input denom-mini-input" type="number" min="0" value="@Model.Denomination.Qty25Cent" />
                                        </div>

                                        <div class="denom-mini">
                                            <div class="denom-mini-label">10c</div>
                                            <input id="Denom_10Cent" class="form-control denom-input denom-mini-input" type="number" min="0" value="@Model.Denomination.Qty10Cent" />
                                        </div>

                                        <div class="denom-mini">
                                            <div class="denom-mini-label">5c</div>
                                            <input id="Denom_5Cent" class="form-control denom-input denom-mini-input" type="number" min="0" value="@Model.Denomination.Qty5Cent" />
                                        </div>

                                        <div class="denom-mini">
                                            <div class="denom-mini-label">1c</div>
                                            <input id="Denom_1Cent" class="form-control denom-input denom-mini-input" type="number" min="0" value="@Model.Denomination.Qty1Cent" />
                                        </div>
                                    </div>

                                    <div class="denom-save-hint mt-3">
                                        Finalize only works when total denomination exactly matches the target.
                                    </div>
                                </div>

                                <div>
                                    <div id="denomSidebox"
                                         class="denom-total-box @(Model.GrandTotal <= 0 ? "status-waiting" : (Model.IsDenominationMatched ? "status-match" : (Model.DenominationDifference < 0 ? "status-missing" : "status-over")))">
                                        <div class="denom-total-title">Total / Target</div>

                                        <div id="denomRemaining" class="denom-total-main">
                                            @((Model.GrandTotal - Model.DenominationTotal).ToString("0.00"))
                                        </div>

                                        <div id="denomHelperText" class="denom-total-helper">
                                            @(Model.GrandTotal <= 0
                                                ? "Add entries first, then enter the denomination."
                                                : (Model.IsDenominationMatched
                                                ? "Exact match. You can finalize this record."
                                                : (Model.DenominationDifference > 0
                                                ? "Denomination is over the target."
                                                : "Keep entering denomination until the remaining target becomes 0.00.")))
                                        </div>

                                        <div class="denom-total-lines">
                                            <div class="denom-total-line">
                                                <span>Target</span>
                                                <strong id="denomTarget">@Model.GrandTotal.ToString("0.00")</strong>
                                            </div>
                                            <div class="denom-total-line">
                                                <span>Entered</span>
                                                <strong id="denomTotal">@Model.DenominationTotal.ToString("0.00")</strong>
                                            </div>
                                            <div class="denom-total-line">
                                                <span>Difference</span>
                                                <strong id="denomDifference">@Model.DenominationDifference.ToString("0.00")</strong>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div id="denomSummarySection" class="@(Model.IsClosed ? "" : "d-none")">
                        <div class="denom-final-wrap">
                            <div class="denom-final-left">
                                <div class="denom-final-label">Denomination Summary</div>

                                <div id="denomSummaryRows">
                                    @{
                                        var denomItems = new List<(string Label, int Qty, decimal Amount)>
                                        {
                                            ("1000", Model.Denomination.Qty1000, Model.Denomination.Qty1000 * 1000m),
                                            ("500", Model.Denomination.Qty500, Model.Denomination.Qty500 * 500m),
                                            ("200", Model.Denomination.Qty200, Model.Denomination.Qty200 * 200m),
                                            ("100", Model.Denomination.Qty100, Model.Denomination.Qty100 * 100m),
                                            ("50", Model.Denomination.Qty50, Model.Denomination.Qty50 * 50m),
                                            ("20 Coins", Model.Denomination.Qty20Coin, Model.Denomination.Qty20Coin * 20m),
                                            ("20 Paper", Model.Denomination.Qty20Paper, Model.Denomination.Qty20Paper * 20m),
                                            ("10", Model.Denomination.Qty10, Model.Denomination.Qty10 * 10m),
                                            ("5", Model.Denomination.Qty5, Model.Denomination.Qty5 * 5m),
                                            ("1", Model.Denomination.Qty1, Model.Denomination.Qty1 * 1m),
                                            ("25c", Model.Denomination.Qty25Cent, Model.Denomination.Qty25Cent * 0.25m),
                                            ("10c", Model.Denomination.Qty10Cent, Model.Denomination.Qty10Cent * 0.10m),
                                            ("5c", Model.Denomination.Qty5Cent, Model.Denomination.Qty5Cent * 0.05m),
                                            ("1c", Model.Denomination.Qty1Cent, Model.Denomination.Qty1Cent * 0.01m)
                                        };

                                        var usedDenoms = denomItems.Where(x => x.Qty > 0).ToList();
                                    }

                                    @if (usedDenoms.Any())
                                    {
                                        <div class="denom-final-list">
                                            @foreach (var item in usedDenoms)
                                            {
                                                <div class="denom-final-row">
                                                    <div class="denom-final-row-left">
                                                        <span class="denom-final-bill">@item.Label</span>
                                                        <span class="denom-final-times">× @item.Qty</span>
                                                    </div>
                                                    <div class="denom-final-row-amount">@item.Amount.ToString("0.00")</div>
                                                </div>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="denom-final-empty">No denomination recorded.</div>
                                    }
                                </div>
                            </div>

                            <div class="denom-final-right">
                                <div class="denom-final-total-card">
                                    <div class="denom-final-total-label">Total Denomination</div>
                                    <div id="denomSummaryTotal" class="denom-final-total-value">@Model.DenominationTotal.ToString("0.00")</div>

                                    <div class="denom-final-total-meta">
                                        <div class="denom-final-total-line">
                                            <span>Target</span>
                                            <strong id="denomSummaryTarget">@Model.GrandTotal.ToString("0.00")</strong>
                                        </div>
                                        <div class="denom-final-total-line">
                                            <span>Difference</span>
                                            <strong id="denomSummaryDifference" class="@(Model.DenominationDifference == 0 ? "ok" : "bad")">
                                                @Model.DenominationDifference.ToString("0.00")
                                            </strong>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
        
    </div>
</div>

<div class="toast-container position-fixed bottom-0 end-0 p-3">
    <div id="floatingToast" class="toast floating-toast border-0 shadow" role="alert" aria-live="assertive" aria-atomic="true">
        <div id="floatingToastHeader" class="toast-header">
            <strong class="me-auto" id="toastTitle">Notice</strong>
            <small>Now</small>
            <button type="button" class="btn-close ms-2 mb-1" data-bs-dismiss="toast"></button>
        </div>
        <div class="toast-body" id="toastBody"></div>
    </div>
</div>

<div class="modal fade" id="finalizeModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Finalize Record</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                Are you sure you want to finalize this record?
                <div class="mt-2 text-muted small">
                    After finalizing, the member list and entry form will be hidden.
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-primary" id="confirmFinalizeBtn">Yes, Finalize</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let isFinalizing = false;
        let isSavingRow = false;
        let actionBannerTimer = null;
        let denominationSaveTimer = null;
        let denominationSaveInFlight = false;

        function applyDenominationMode(isClosed) {
            const inputSection = document.getElementById("denomInputSection");
            const summarySection = document.getElementById("denomSummarySection");

            if (inputSection) {
                inputSection.classList.toggle("d-none", !!isClosed);
            }

            if (summarySection) {
                summarySection.classList.toggle("d-none", !isClosed);
            }

            document.querySelectorAll(".denom-input").forEach(input => {
                input.disabled = !!isClosed;
            });
        }

        function getDenominationPayload() {
            return {
                qty1000: parseInt(document.getElementById("Denom_1000")?.value || "0") || 0,
                qty500: parseInt(document.getElementById("Denom_500")?.value || "0") || 0,
                qty200: parseInt(document.getElementById("Denom_200")?.value || "0") || 0,
                qty100: parseInt(document.getElementById("Denom_100")?.value || "0") || 0,
                qty50: parseInt(document.getElementById("Denom_50")?.value || "0") || 0,
                qty20Coin: parseInt(document.getElementById("Denom_20Coin")?.value || "0") || 0,
                qty20Paper: parseInt(document.getElementById("Denom_20Paper")?.value || "0") || 0,
                qty10: parseInt(document.getElementById("Denom_10")?.value || "0") || 0,
                qty5: parseInt(document.getElementById("Denom_5")?.value || "0") || 0,
                qty1: parseInt(document.getElementById("Denom_1")?.value || "0") || 0,
                qty25Cent: parseInt(document.getElementById("Denom_25Cent")?.value || "0") || 0,
                qty10Cent: parseInt(document.getElementById("Denom_10Cent")?.value || "0") || 0,
                qty5Cent: parseInt(document.getElementById("Denom_5Cent")?.value || "0") || 0,
                qty1Cent: parseInt(document.getElementById("Denom_1Cent")?.value || "0") || 0
            };
        }

        function computeDenomTotal(denom) {
            return (denom.qty1000 * 1000) +
                   (denom.qty500 * 500) +
                   (denom.qty200 * 200) +
                   (denom.qty100 * 100) +
                   (denom.qty50 * 50) +
                   (denom.qty20Coin * 20) +
                   (denom.qty20Paper * 20) +
                   (denom.qty10 * 10) +
                   (denom.qty5 * 5) +
                   (denom.qty1 * 1) +
                   (denom.qty25Cent * 0.25) +
                   (denom.qty10Cent * 0.10) +
                   (denom.qty5Cent * 0.05) +
                   (denom.qty1Cent * 0.01);
        }

        function fillDenominationInputs(denom) {
            const safeDenom = denom || {};

            const setValue = (id, value) => {
                const el = document.getElementById(id);
                if (el) el.value = value ?? 0;
            };

            setValue("Denom_1000", safeDenom.qty1000 || 0);
            setValue("Denom_500", safeDenom.qty500 || 0);
            setValue("Denom_200", safeDenom.qty200 || 0);
            setValue("Denom_100", safeDenom.qty100 || 0);
            setValue("Denom_50", safeDenom.qty50 || 0);
            setValue("Denom_20Coin", safeDenom.qty20Coin || 0);
            setValue("Denom_20Paper", safeDenom.qty20Paper || 0);
            setValue("Denom_10", safeDenom.qty10 || 0);
            setValue("Denom_5", safeDenom.qty5 || 0);
            setValue("Denom_1", safeDenom.qty1 || 0);
            setValue("Denom_25Cent", safeDenom.qty25Cent || 0);
            setValue("Denom_10Cent", safeDenom.qty10Cent || 0);
            setValue("Denom_5Cent", safeDenom.qty5Cent || 0);
            setValue("Denom_1Cent", safeDenom.qty1Cent || 0);
        }

        function renderDenominationSummary(denomData, grandTotal) {
            const denom = denomData || {};

            const items = [
                { label: "1000", qty: denom.qty1000 || 0, amount: (denom.qty1000 || 0) * 1000 },
                { label: "500", qty: denom.qty500 || 0, amount: (denom.qty500 || 0) * 500 },
                { label: "200", qty: denom.qty200 || 0, amount: (denom.qty200 || 0) * 200 },
                { label: "100", qty: denom.qty100 || 0, amount: (denom.qty100 || 0) * 100 },
                { label: "50", qty: denom.qty50 || 0, amount: (denom.qty50 || 0) * 50 },
                { label: "20 Coins", qty: denom.qty20Coin || 0, amount: (denom.qty20Coin || 0) * 20 },
                { label: "20 Paper", qty: denom.qty20Paper || 0, amount: (denom.qty20Paper || 0) * 20 },
                { label: "10", qty: denom.qty10 || 0, amount: (denom.qty10 || 0) * 10 },
                { label: "5", qty: denom.qty5 || 0, amount: (denom.qty5 || 0) * 5 },
                { label: "1", qty: denom.qty1 || 0, amount: (denom.qty1 || 0) * 1 },
                { label: "25c", qty: denom.qty25Cent || 0, amount: (denom.qty25Cent || 0) * 0.25 },
                { label: "10c", qty: denom.qty10Cent || 0, amount: (denom.qty10Cent || 0) * 0.10 },
                { label: "5c", qty: denom.qty5Cent || 0, amount: (denom.qty5Cent || 0) * 0.05 },
                { label: "1c", qty: denom.qty1Cent || 0, amount: (denom.qty1Cent || 0) * 0.01 }
            ];

            const rowsHost = document.getElementById("denomSummaryRows");
            const totalEl = document.getElementById("denomSummaryTotal");
            const targetEl = document.getElementById("denomSummaryTarget");
            const diffEl = document.getElementById("denomSummaryDifference");

            if (rowsHost) {
                const visibleItems = items.filter(x => x.qty > 0);

                if (visibleItems.length === 0) {
                    rowsHost.innerHTML = `<div class="denom-final-empty">No denomination recorded.</div>`;
                } else {
                    rowsHost.innerHTML = `
                        <div class="denom-final-list">
                            ${visibleItems.map(x => `
                                <div class="denom-final-row">
                                    <div class="denom-final-row-left">
                                        <span class="denom-final-bill">${escapeHtml(x.label)}</span>
                                        <span class="denom-final-times">× ${x.qty}</span>
                                    </div>
                                    <div class="denom-final-row-amount">${formatMoney(x.amount)}</div>
                                </div>
                            `).join("")}
                        </div>
                    `;
                }
            }

            const total = denom.total !== undefined && denom.total !== null
                ? parseFloat(denom.total)
                : computeDenomTotal(denom);

            const target = parseFloat(grandTotal || 0);
            const difference = total - target;

            if (totalEl) totalEl.textContent = formatMoney(total);
            if (targetEl) targetEl.textContent = formatMoney(target);

            if (diffEl) {
                diffEl.textContent = formatMoney(difference);
                diffEl.className = difference === 0 ? "ok" : "bad";
            }
        }

        function renderDenominationState(denomData, grandTotal) {
            const denom = denomData || {};

            const target = grandTotal !== undefined && grandTotal !== null
                ? parseFloat(grandTotal)
                : parseFloat(denom.target || 0);

            const total = denom.total !== undefined && denom.total !== null
                ? parseFloat(denom.total)
                : computeDenomTotal(getDenominationPayload());

            const difference = total - target;
            const remaining = target - total;
            const isMatched = target > 0 && difference === 0;

            const targetEl = document.getElementById("denomTarget");
            const totalEl = document.getElementById("denomTotal");
            const differenceEl = document.getElementById("denomDifference");
            const remainingEl = document.getElementById("denomRemaining");

            if (targetEl) targetEl.textContent = formatMoney(target);
            if (totalEl) totalEl.textContent = formatMoney(total);
            if (differenceEl) differenceEl.textContent = formatMoney(difference);
            if (remainingEl) remainingEl.textContent = formatMoney(remaining);

            let statusClass = "waiting";
            let sideClass = "status-waiting";
            let statusText = "Waiting";
            let helperText = "Add entries first, then enter the denomination.";

            if (target > 0) {
                if (isMatched) {
                    statusClass = "match";
                    sideClass = "status-match";
                    statusText = "Matched";
                    helperText = "Exact match. You can finalize this record.";
                } else if (difference > 0) {
                    statusClass = "over";
                    sideClass = "status-over";
                    statusText = "Over";
                    helperText = "Denomination is over the target.";
                } else {
                    statusClass = "missing";
                    sideClass = "status-missing";
                    statusText = "Missing";
                    helperText = "Keep entering denomination until the remaining target becomes 0.00.";
                }
            }

            const statusPill = document.getElementById("denomStatusPill");
            const sideBox = document.getElementById("denomSidebox");
            const helperTextEl = document.getElementById("denomHelperText");

            if (statusPill) {
                statusPill.className = "denom-status " + statusClass;
                statusPill.textContent = statusText;
            }

            if (sideBox) {
                sideBox.className = "denom-total-box " + sideClass;
            }

            if (helperTextEl) {
                helperTextEl.textContent = helperText;
            }

            const isAlreadyClosed = (document.getElementById("recordStatusBadge")?.textContent || "").includes("Finalized");
            const canFinalize = isMatched && target > 0 && !isAlreadyClosed;

            const finalizeBtn = document.getElementById("finalizeBtn");
            const confirmFinalizeBtn = document.getElementById("confirmFinalizeBtn");

            if (finalizeBtn && !finalizeBtn.classList.contains("d-none")) {
                finalizeBtn.disabled = !canFinalize;
            }

            if (confirmFinalizeBtn) {
                confirmFinalizeBtn.disabled = !canFinalize;
            }
        }

        function queueDenominationSave() {
            if (denominationSaveTimer) clearTimeout(denominationSaveTimer);

            denominationSaveTimer = setTimeout(async () => {
                if (denominationSaveInFlight) return;
                denominationSaveInFlight = true;
                try {
                    await saveDenominationAjax();
                } finally {
                    denominationSaveInFlight = false;
                }
            }, 350);
        }

        async function saveDenominationAjax() {
            const recordId = parseInt(document.getElementById("RecordId")?.value || "0");
            if (!recordId) return;

            const targetTotal = parseAmount(document.getElementById("grandTotal")?.textContent || "0");

            try {
                const response = await fetch("?handler=SaveDenominationAjax", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                        "RequestVerificationToken": getAntiForgeryToken()
                    },
                    body: JSON.stringify({
                        recordId: recordId,
                        denomination: getDenominationPayload(),
                        targetTotal: targetTotal
                    })
                });

                const data = await response.json();
                if (data.success) {
                    const payload = data.data;
                    renderDenominationState(payload.denomination, payload.totals?.grandTotal);
                }
            } catch (err) {
                console.error("Denomination save error:", err);
            }
        }

                function renderTotals(totals) {
            const setText = (id, value, useComma = false) => {
                const el = document.getElementById(id);
                if (!el) return;

                el.textContent = useComma ? formatMoneyTotal(value) : formatMoney(value);
            };

            setText("totalTithes", totals.totalTithes, true);
            setText("totalOfferings", totals.totalOfferings, true);
            setText("totalSolomon", totals.totalSolomon, true);
            setText("totalNoah", totals.totalNoah, true);
            setText("totalMission", totals.totalMission, true);
            setText("totalOthers", totals.totalOthers, true);
            setText("grandTotal", totals.grandTotal, true);

            renderDenominationState(null, totals.grandTotal);
        }

        function setSaveRowBusyState(isBusy) {
            const saveBtn = document.getElementById("saveMemberBtn");
            if (!saveBtn) return;
            saveBtn.disabled = isBusy;
            saveBtn.classList.toggle("btn-finalizing", isBusy);
            saveBtn.textContent = isBusy ? "Saving..." : "Save Row";
        }

        function parseAmount(value) {
            const num = parseFloat(value);
            return isNaN(num) ? 0 : num;
        }

        function formatMoney(value) {
            const num = parseFloat(value || 0);
            return num === 0 ? "" : num.toFixed(2);
        }
        function formatMoneyTotal(value) {
            const num = parseFloat(value || 0);
            if (num === 0) return "";

            return num.toLocaleString("en-US", {
                minimumFractionDigits: 2,
                maximumFractionDigits: 2
            });
        }

        function escapeHtml(text) {
            return (text ?? "")
                .replaceAll("&", "&amp;")
                .replaceAll("<", "&lt;")
                .replaceAll(">", "&gt;")
                .replaceAll('"', "&quot;")
                .replaceAll("'", "&#039;");
        }

        function formatDateLabel(dateValue) {
            if (!dateValue) return "";
            const dt = new Date(dateValue);
            if (!isNaN(dt.getTime())) {
                const mm = String(dt.getMonth() + 1).padStart(2, "0");
                const dd = String(dt.getDate()).padStart(2, "0");
                const yyyy = dt.getFullYear();
                return `${mm}/${dd}/${yyyy}`;
            }
            return dateValue;
        }

        function getRowClassByName(name) {
            const lower = (name || "").toLowerCase();
            if (lower.includes("kids") || lower.includes("prayer") || lower.includes("youth") || lower.includes("camp") || lower.includes("meeting") || lower.includes("group")) {
                return "name-group";
            }
            if ((name || "").includes("&")) {
                return "name-family";
            }
            return "";
        }

        function getAntiForgeryToken() {
            return document.querySelector('#recordHeaderForm input[name="__RequestVerificationToken"]')?.value
                || document.querySelector('#memberEntryForm input[name="__RequestVerificationToken"]')?.value
                || document.querySelector('input[name="__RequestVerificationToken"]')?.value
                || "";
        }

        function updateDisplayTotal() {
            const total =
                parseAmount(document.getElementById("Input_Tithes")?.value) +
                parseAmount(document.getElementById("Input_Offerings")?.value) +
                parseAmount(document.getElementById("Input_Solomon")?.value) +
                parseAmount(document.getElementById("Input_Noah")?.value) +
                parseAmount(document.getElementById("Input_Mission")?.value) +
                parseAmount(document.getElementById("Input_Others")?.value);

            const totalBox = document.getElementById("displayTotal");
            if (totalBox) {
                totalBox.value = total.toFixed(2);
            }
        }

        function showToast(title, message, success = true) {
            const toastEl = document.getElementById("floatingToast");
            const header = document.getElementById("floatingToastHeader");
            const body = document.getElementById("toastBody");
            const titleEl = document.getElementById("toastTitle");

            if (!toastEl || !header || !body || !titleEl) return;

            titleEl.textContent = title;
            body.textContent = message;
            header.className = "toast-header " + (success ? "text-bg-success" : "text-bg-danger");

            const existingToast = bootstrap.Toast.getInstance(toastEl);
            if (existingToast) existingToast.dispose();

            const toast = new bootstrap.Toast(toastEl, { autohide: true, delay: 2600 });
            toast.show();
        }

        function showActionBanner(type, title, message, closable = true) {
            const banner = document.getElementById("actionBanner");
            const spinner = document.getElementById("actionBannerSpinner");
            const titleEl = document.getElementById("actionBannerTitle");
            const messageEl = document.getElementById("actionBannerMessage");
            const closeBtn = document.getElementById("actionBannerCloseBtn");

            if (!banner || !spinner || !titleEl || !messageEl || !closeBtn) return;

            if (actionBannerTimer) {
                clearTimeout(actionBannerTimer);
                actionBannerTimer = null;
            }

            banner.className = "action-banner " + type;
            titleEl.textContent = title || "";
            messageEl.textContent = message || "";

            if (type === "loading") spinner.classList.remove("d-none");
            else spinner.classList.add("d-none");

            closeBtn.style.display = closable ? "inline-block" : "none";

            requestAnimationFrame(() => {
                banner.classList.add("show");
            });

            if (type !== "loading") {
                actionBannerTimer = setTimeout(() => { hideActionBanner(); }, 3600);
            }
        }

        function hideActionBanner() {
            const banner = document.getElementById("actionBanner");
            if (!banner) return;

            if (actionBannerTimer) {
                clearTimeout(actionBannerTimer);
                actionBannerTimer = null;
            }

            banner.classList.remove("show");
            setTimeout(() => {
                if (banner) banner.className = "action-banner";
            }, 250);
        }

